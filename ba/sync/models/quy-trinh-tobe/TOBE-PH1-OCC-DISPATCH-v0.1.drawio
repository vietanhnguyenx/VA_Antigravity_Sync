                <mxCell id="m5" value="5. Gắn trạng thái DR&#xa;cho phiên bản OFP tương ứng" style="html=1;endArrow=block;endFill=1;fontSize=10;align=left;verticalAlign=middle;edgeStyle=orthogonalEdgeStyle;exitX=1;exitY=0.545;exitDx=0;exitDy=0;entryX=1;entryY=0.596;entryDx=0;entryDy=0;jumpStyle=arc;jumpSize=6;" parent="1" source="lf_TOSS" target="lf_TOSS" edge="1">
