                <mxCell id="m7" value="7. Cho phép Captain&#39;s Release&#xa;(sau khi có DR)" style="html=1;endArrow=block;endFill=1;fontSize=10;align=left;verticalAlign=middle;edgeStyle=orthogonalEdgeStyle;exitX=1;exitY=0.737;exitDx=0;exitDy=0;entryX=1;entryY=0.788;entryDx=0;entryDy=0;jumpStyle=arc;jumpSize=6;" parent="1" source="lf_MOPlus" target="lf_MOPlus" edge="1">
