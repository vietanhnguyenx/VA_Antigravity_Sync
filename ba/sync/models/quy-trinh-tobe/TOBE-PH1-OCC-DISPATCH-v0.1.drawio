                <mxCell id="m1" value="1. OFP mới / cập nhật (adapter tự động)" style="html=1;endArrow=block;endFill=1;fontSize=10;align=center;verticalAlign=bottom;edgeStyle=orthogonalEdgeStyle;exitX=0;exitY=0.109;exitDx=0;exitDy=0;entryX=1;entryY=0.109;entryDx=0;entryDy=0;jumpStyle=arc;jumpSize=6;" parent="1" source="lf_Lido" target="lf_TOSS" edge="1">
