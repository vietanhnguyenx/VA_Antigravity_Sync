<mxfile host="app.diagrams.net" type="device">
  <diagram id="tich-hop-toss" name="Tích hợp TOSS ↔ Hệ thống Ngoài">
    <mxGraphModel dx="1100" dy="760" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1169" pageHeight="826" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Tiêu đề -->
        <mxCell id="title" value="Mô hình Tích hợp TOSS ↔ Hệ thống Ngoài (v0.1) — nét liền = Thông qua TOSS (trong scope); nét đứt = Trực tiếp/ngữ cảnh" style="text;html=1;fontStyle=1;fontSize=13;align=left;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="40" y="10" width="1080" height="24" as="geometry" /></mxCell>

        <!-- TOSS hub -->
        <mxCell id="toss" value="TOSS&#10;(Hub tích hợp)" style="shape=hexagon;perimeter=hexagonPerimeter2;whiteSpace=wrap;html=1;fontStyle=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;" vertex="1" parent="1"><mxGeometry x="470" y="360" width="170" height="90" as="geometry" /></mxCell>

        <!-- ISB / LHS (hạ tầng) -->
        <mxCell id="isb" value="ISB / LHS&#10;(Trục tích hợp)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1"><mxGeometry x="700" y="375" width="110" height="60" as="geometry" /></mxCell>

        <!-- INBOUND (trái) -->
        <mxCell id="sita" value="SITA&#10;(Mạng điện văn HK)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1"><mxGeometry x="40" y="60" width="180" height="56" as="geometry" /></mxCell>
        <mxCell id="amadeus" value="Amadeus PSS&#10;(Đặt chỗ / khách)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1"><mxGeometry x="40" y="140" width="180" height="56" as="geometry" /></mxCell>
        <mxCell id="aves" value="AVES&#10;(Quản lý tổ bay VNA)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1"><mxGeometry x="40" y="220" width="180" height="56" as="geometry" /></mxCell>
        <mxCell id="vms" value="VMS / VIAGS&#10;(Mặt đất sân bay)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1"><mxGeometry x="40" y="300" width="180" height="56" as="geometry" /></mxCell>
        <mxCell id="acdm" value="A-CDM&#10;(Phối hợp ra QĐ sân bay)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1"><mxGeometry x="40" y="380" width="180" height="56" as="geometry" /></mxCell>
        <mxCell id="cargo" value="Cargo Spot&#10;(Hàng hóa)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1"><mxGeometry x="40" y="460" width="180" height="56" as="geometry" /></mxCell>
        <mxCell id="sabreIn" value="Sabre (GDS)&#10;(Lịch mùa SSIM)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1"><mxGeometry x="40" y="540" width="180" height="56" as="geometry" /></mxCell>

        <!-- OUTBOUND / ĐÍCH (phải) -->
        <mxCell id="opspp" value="OPS++ / NetOps++&#10;(LHS — hệ khai thác chính)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontStyle=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="900" y="340" width="200" height="90" as="geometry" /></mxCell>
        <mxCell id="sabreOut" value="Sabre (GDS)&#10;(nhận ASM / ACH)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1"><mxGeometry x="900" y="540" width="200" height="56" as="geometry" /></mxCell>

        <!-- NGỮ CẢNH (nét đứt) -->
        <mxCell id="lido" value="Lido&#10;(Kế hoạch bay — OFP)" style="rounded=1;whiteSpace=wrap;html=1;dashed=1;fillColor=#f5f5f5;strokeColor=#999999;fontSize=11;" vertex="1" parent="1"><mxGeometry x="320" y="640" width="170" height="56" as="geometry" /></mxCell>
        <mxCell id="amos" value="AMOS&#10;(Bảo dưỡng — MEL Item)" style="rounded=1;whiteSpace=wrap;html=1;dashed=1;fillColor=#f5f5f5;strokeColor=#999999;fontSize=11;" vertex="1" parent="1"><mxGeometry x="540" y="640" width="170" height="56" as="geometry" /></mxCell>

        <!-- EDGE: INBOUND → TOSS (nét liền) -->
        <mxCell id="e1" value="MVT·MVA·DIV·LDM&#10;SFTP/Email · BR-556…559" style="endArrow=block;html=1;fontSize=10;" edge="1" parent="1" source="sita" target="toss"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e2" value="PTM·PNL·ADL·Pax Detail&#10;BR-563…566" style="endArrow=block;html=1;fontSize=10;" edge="1" parent="1" source="amadeus" target="toss"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e3" value="Crew Assignment/Connection&#10;BR-567 · BR-568" style="endArrow=block;html=1;fontSize=10;" edge="1" parent="1" source="aves" target="toss"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e4" value="Gate info (API VIAGS)&#10;BR-569" style="endArrow=block;html=1;fontSize=10;" edge="1" parent="1" source="vms" target="toss"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e5" value="Flight data A-CDM 16 mốc&#10;BR-570 [cần xác nhận]" style="endArrow=block;html=1;fontSize=10;" edge="1" parent="1" source="acdm" target="toss"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e6" value="Cargo manifest&#10;BR-572" style="endArrow=block;html=1;fontSize=10;" edge="1" parent="1" source="cargo" target="toss"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e7" value="SSIM lịch mùa&#10;SFTP · BR-562" style="endArrow=block;html=1;fontSize=10;" edge="1" parent="1" source="sabreIn" target="toss"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- EDGE: TOSS → ISB → OPS++ -->
        <mxCell id="e8" value="Forward 17 luồng inbound + FMM/Fuel Report (tự sinh)&#10;VPN · SFTP/ISB · BR-560/561/575…581" style="endArrow=block;html=1;fontSize=10;" edge="1" parent="1" source="toss" target="isb"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e9" value="" style="endArrow=block;html=1;" edge="1" parent="1" source="isb" target="opspp"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- EDGE: OUTBOUND OPS++/NetLine → TOSS → Sabre (2 luồng ASM/ACH) -->
        <mxCell id="e10" value="ASM · ACH (lịch chuyến)&#10;2 luồng outbound" style="endArrow=block;html=1;fontSize=10;" edge="1" parent="1" source="opspp" target="toss"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e11" value="ASM · ACH → Sabre&#10;(TOSS chế biến/chuyển)" style="endArrow=block;html=1;fontSize=10;" edge="1" parent="1" source="toss" target="sabreOut"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- EDGE: NGỮ CẢNH (nét đứt) — TOSS kết nối trực tiếp lấy dữ liệu nội bộ -->
        <mxCell id="c1" value="OFP (nội bộ)" style="endArrow=block;html=1;dashed=1;strokeColor=#999999;fontSize=10;fontColor=#666666;" edge="1" parent="1" source="lido" target="toss"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="c2" value="MEL Item (nội bộ)" style="endArrow=block;html=1;dashed=1;strokeColor=#999999;fontSize=10;fontColor=#666666;" edge="1" parent="1" source="amos" target="toss"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="c3" value="Trực tiếp → NetOps++&#10;(ngoài luồng relay TOSS)" style="endArrow=block;html=1;dashed=1;strokeColor=#999999;fontSize=10;fontColor=#666666;" edge="1" parent="1" source="lido" target="opspp"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="c4" value="Trực tiếp → NetOps++" style="endArrow=block;html=1;dashed=1;strokeColor=#999999;fontSize=10;fontColor=#666666;" edge="1" parent="1" source="amos" target="opspp"><mxGeometry relative="1" as="geometry" /></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
