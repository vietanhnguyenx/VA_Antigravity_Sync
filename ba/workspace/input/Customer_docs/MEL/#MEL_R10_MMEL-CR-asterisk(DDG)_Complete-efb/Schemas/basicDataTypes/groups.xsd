<xs:include schemaLocation="../attributeTypes/generalAttrs.xsd"/>
<xs:import namespace="http://www.boeing.com/FTID-ML/Revision" schemaLocation="../metadataTypes/revision.xsd"/>
<xs:include schemaLocation="text.xsd"/>
<xs:include schemaLocation="cwnc.xsd"/>
<xs:include schemaLocation="table.xsd"/>
<xs:include schemaLocation="graphic.xsd"/>


<!--=====================================================-->
<!-- Declare one global attribute group and to be re-used in any elements -->
<!--=====================================================-->
<xs:attributeGroup name="globalAttrGrp">
    <xs:annotation>
        <xs:documentation>Include common attributes for coc and revision management that are used by most elements</xs:documentation>
    </xs:annotation>

    <xs:attribute name="coc" type="cocType" use="optional"/>
    <xs:attributeGroup ref="rev:revAttrGrp"/>

</xs:attributeGroup>


<!--=====================================================-->
<!--  General text group  -->
<!--=====================================================-->
<xs:group name="TextGroupType">
    <xs:choice>
        <xs:element name="GraphicSet" type="GraphicSetType"/>
        <xs:element name="List" type="ListType"/>
        <xs:element name="Para" type="ParaType"/>
        <xs:element name="table" type="tableType"/>
    </xs:choice>
</xs:group>

<!--=====================================================-->
<!--  General text & CWN group  -->
<!--=====================================================-->
<xs:group name="TextCWNGroupType">
    <xs:choice>
        <xs:element name="Caution" type="CautionType"/>
        <xs:element name="Warning" type="WarningType"/>
        <xs:element name="GraphicSet" type="GraphicSetType"/>
        <xs:element name="List" type="ListType"/>
        <xs:element name="Para" type="ParaType"/>
        <xs:element name="table" type="tableType"/>
        <xs:element name="Note" type="NoteType"/>
    </xs:choice>
</xs:group>

<!--=====================================================-->
<!--  Short Text group with Para & List only  -->
<!--=====================================================-->
<xs:group name="ShortTextGroupType">
    <xs:choice>
        <xs:element name="List" type="ListType"/>
        <xs:element name="Para" type="ParaType"/>
    </xs:choice>
</xs:group>

<!--=====================================================-->
<!--  Short Text group with Note  -->
<!--=====================================================-->
<xs:group name="ShortTextNoteGroupType">
    <xs:choice>
        <xs:element name="List" type="ListType"/>
        <xs:element name="Para" type="ParaType"/>
        <xs:element name="Note" type="NoteType"/>
    </xs:choice>
</xs:group>

<!--=====================================================-->
<!--  caution,warning,note group -->
<!--=====================================================-->
<xs:group name="CWNGroupType">
    <xs:choice>
        <xs:element name="Caution" type="CautionType"/>
        <xs:element name="Warning" type="WarningType"/>
        <xs:element name="Note" type="NoteType"/>
    </xs:choice>
</xs:group>


<!--=====================================================-->
<!-- Comment,caution,warning,note group -->
<!--=====================================================-->
<xs:group name="CCWNGroupType">
    <xs:choice>
        <xs:element name="Comment" type="CommentType"/>
        <xs:element name="Caution" type="CautionType"/>
        <xs:element name="Warning" type="WarningType"/>
        <xs:element name="Note" type="NoteType"/>
    </xs:choice>
</xs:group>


<!--=====================================================-->
<!-- Comment,caution,warning group -->
<!--=====================================================-->
<xs:group name="CCWGroupType">
    <xs:choice>
        <xs:element name="Comment" type="CommentType"/>
        <xs:element name="Caution" type="CautionType"/>
        <xs:element name="Warning" type="WarningType"/>
    </xs:choice>
</xs:group>


</xs:schema>
