<!--=====================================================-->
<!-- ATASystems element definition -->
<!--=====================================================-->
<xs:complexType name="ATASystemsType">
    <xs:annotation>
        <xs:documentation>ATA Systems Definition</xs:documentation>
    </xs:annotation>

    <xs:choice>
        <xs:element name="ATASystemsAll" type="ATASystemsAllType"/>
        <xs:element name="ATASystemsNone" type="ATASystemsNoneType"/>
        <xs:element name="ATASystemsList" type="ATASystemsListType" maxOccurs="unbounded"/>
    </xs:choice>
</xs:complexType>


<!--=====================================================-->
<!--  ATASystemsAll element definition -->
<!--=====================================================-->
<xs:complexType name="ATASystemsAllType">
    <xs:annotation>
        <xs:documentation>All applicable systems</xs:documentation>
    </xs:annotation>

    <xs:attribute name="code" type="xs:string" fixed="ALL"/>
    <xs:attribute name="desc" type="xs:string" fixed="All Systems"/>
</xs:complexType>


<!--=====================================================-->
<!--  ATASystemsNone element definition -->
<!--=====================================================-->
<xs:complexType name="ATASystemsNoneType">
    <xs:annotation>
        <xs:documentation>No applicable system</xs:documentation>
    </xs:annotation>

    <xs:attribute name="code" type="xs:string" fixed="NIL"/>
    <xs:attribute name="desc" type="xs:string" fixed="Not Applicable"/>
</xs:complexType>


