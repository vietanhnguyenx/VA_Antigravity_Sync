<!--=====================================================-->
<!-- Revision Attribute Group element definition -->
<!--=====================================================-->
<xs:attributeGroup name="revAttrGrp">
    <xs:annotation>
        <xs:documentation>
        </xs:documentation>
    </xs:annotation>

    <xs:attribute name="revStatus" type="revStatusType" use="optional" default="U"/>
    <xs:attribute name="revNumber" type="revNumberType" use="optional"/>
    <xs:attribute name="revDate" type="DateType" use="optional"/>
    <xs:attribute name="revHighlight" type="revHighlightType" use="optional"/>
    <xs:attribute name="revExpireDate" type="DateType" use="optional"/>

</xs:attributeGroup>



<!--=====================================================-->
<!--  Revision Status Type element definition -->
<!--  U=unchanged, R=Revised, N=New, D=Deleted, M=Moved, T=Temporary -->
<!--=====================================================-->
<xs:simpleType name="revStatusType">
    <xs:annotation>
        <xs:documentation>Status of the data in respect to the current revision cycle</xs:documentation>
    </xs:annotation>

    <xs:restriction base="xs:NMTOKEN">
        <xs:enumeration value="U"/>
        <xs:enumeration value="R"/>
        <xs:enumeration value="N"/>
        <xs:enumeration value="D"/>
        <xs:enumeration value="M"/>
        <xs:enumeration value="T"/>
    </xs:restriction>
</xs:simpleType>


<!--=====================================================-->
<!--  Date attribute definition -->
<!--=====================================================-->
<xs:simpleType name="DateType">
    <xs:annotation>
        <xs:documentation>Date field represents a Gregorian calendar date of CCYY-MM-DD
        </xs:documentation>
    </xs:annotation>

    <xs:restriction base="xs:date"/>
</xs:simpleType>


<!--=====================================================-->
<!-- Revision Highlight (reasons) attribute definition -->
<!--=====================================================-->
<xs:simpleType name="revHighlightType">
    <xs:annotation>
        <xs:documentation>Descriptions for reasons to make the changes</xs:documentation>
    </xs:annotation>

    <xs:restriction base="xs:string">
    </xs:restriction>
</xs:simpleType>


<!--=====================================================-->
<!-- Revision Number attribute definition -->
<!--=====================================================-->
<xs:simpleType name="revNumberType">
    <xs:annotation>
        <xs:documentation>Traditional sequential number of publishing cycle</xs:documentation>
    </xs:annotation>

    <xs:restriction base="xs:string">
        <xs:pattern value="(\c)+"/>
    </xs:restriction>
</xs:simpleType>

</xs:schema>

