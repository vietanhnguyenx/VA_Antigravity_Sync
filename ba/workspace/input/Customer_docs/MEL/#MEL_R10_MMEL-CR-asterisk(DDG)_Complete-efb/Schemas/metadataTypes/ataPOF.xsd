<!--=====================================================-->
<!-- Phases Of Flight element definition -->
<!--=====================================================-->
<xs:complexType name="POFType">
    <xs:annotation>
        <xs:documentation>Phases of Flight Definition Structure</xs:documentation>
    </xs:annotation>

    <xs:choice>
        <xs:element name="POFAll" type="POFAllType" />
        <xs:element name="POFNone" type="POFNoneType" />
        <xs:element name="POFList" type="POFListType" maxOccurs="17"/>
    </xs:choice>
</xs:complexType>

<!--=====================================================-->
<!-- POFAll element definition -->
<!--=====================================================-->
<xs:complexType name="POFAllType">
    <xs:annotation>
        <xs:documentation>All phases applied</xs:documentation>
    </xs:annotation>

    <xs:attribute name="code" type="xs:string" fixed="ALL"/>
    <xs:attribute name="desc" type="xs:string" fixed="All Phases"/>
</xs:complexType>

<!--=====================================================-->
<!-- POFNone element definition -->
<!--=====================================================-->
<xs:complexType name="POFNoneType">
    <xs:annotation>
        <xs:documentation>No phases applied</xs:documentation>
    </xs:annotation>

    <xs:attribute name="code" type="xs:string" fixed="NIL"/>
    <xs:attribute name="desc" type="xs:string" fixed="Not Applicable"/>
</xs:complexType>


<!--=====================================================-->
<!-- POFList element definition -->
<!--=====================================================-->
<xs:complexType name="POFListType">
    <xs:annotation>
        <xs:documentation>List of applicable phases</xs:documentation>
    </xs:annotation>

    <xs:choice>
        <xs:element name="FlightPlanning" type="FLPType"/>
        <xs:element name="PreFlight" type="PRFType"/>
        <xs:element name="EngineStart-Depart" type="ESDType"/>
        <xs:element name="TaxiOut" type="TXOType"/>
        <xs:element name="TakeOff" type="TOFType"/>
        <xs:element name="RejectTakeOff" type="RTOType"/>
        <xs:element name="InitialClimb" type="ICLType"/>
        <xs:element name="EnRouteClimb" type="ECLType"/>
        <xs:element name="Cruise" type="CRZType"/>
        <xs:element name="Descent" type="DSTType"/>
        <xs:element name="Approach" type="APRType"/>
        <xs:element name="GoAround" type="GOAType"/>
        <xs:element name="Landing" type="LNDType"/>
        <xs:element name="TaxiIn" type="TXIType"/>
        <xs:element name="Arrival" type="AESType"/>
        <xs:element name="PostFlight" type="PSFType"/>
        <xs:element name="FlightClose" type="FLCType"/>
        <xs:element name="GroundServicing" type="GRSType"/>
    </xs:choice>
</xs:complexType>


