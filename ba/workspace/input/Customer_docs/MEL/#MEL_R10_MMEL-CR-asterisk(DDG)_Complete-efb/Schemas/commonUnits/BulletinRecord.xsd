<xs:include schemaLocation="../attributeTypes/generalAttrs.xsd"/>
<xs:include schemaLocation="../basicDataTypes/basicDataInclude.xsd"/>
<xs:include schemaLocation="../metadataTypes/effect.xsd"/>
<xs:import namespace="http://www.boeing.com/FTID-ML/Revision" schemaLocation="../metadataTypes/revision.xsd"/>


<!--=====================================================-->
<!--  BulletinRecord element declaration -->
<!--=====================================================-->
<xs:element name="BulletinRecord" type="BulletinRecordType"/>


<!--=====================================================-->
<!--  BulletinRecord element definition -->
<!--=====================================================-->
<xs:complexType name="BulletinRecordType">
    <xs:annotation>
        <xs:documentation>Content-Unit for a List of bulletins, applicable for a configuration</xs:documentation>
    </xs:annotation>

    <xs:sequence>
        <xs:element name="Title" type="TitleType" minOccurs="0"/>
        <xs:choice maxOccurs="unbounded">
            <xs:group ref="TextGroupType"/>
        </xs:choice>
        <xs:element name="BulletinList" type="BulletinListType" minOccurs="0"/>
    </xs:sequence>

    <xs:attribute name="id" type="UIDType" use="required"/>
    <xs:attributeGroup ref="globalAttrGrp"/>
</xs:complexType>


<!--=====================================================-->
<!--  BulletinList element definition -->
<!--=====================================================-->
<xs:complexType name="BulletinListType">
    <xs:annotation>
        <xs:documentation>Container for list of bulletins</xs:documentation>
    </xs:annotation>

    <xs:sequence maxOccurs="unbounded">
        <xs:element name="BulletinItem" type="BulletinItemType"/>
    </xs:sequence>

</xs:complexType>


<!--=====================================================-->
<!--  BulletinItem element definition -->
<!--=====================================================-->
<xs:complexType name="BulletinItemType">
    <xs:annotation>
        <xs:documentation>A bulletin info container</xs:documentation>
    </xs:annotation>

    <xs:sequence>
        <xs:element name="BulletinNumber" type="SimpleMixedContentType"/>
        <xs:element name="BulletinSubject" type="SimpleMixedContentType"/>
        <xs:element name="BulletinRefNo" type="SimpleMixedContentType" minOccurs="0"/>
        <xs:element name="BulletinDate" type="SimpleMixedContentType" minOccurs="0"/>
        <xs:element name="BulletinStatus" type="SimpleMixedContentType" minOccurs="0"/>
    </xs:sequence>

    <xs:attributeGroup ref="globalAttrGrp"/>
</xs:complexType>


</xs:schema>
