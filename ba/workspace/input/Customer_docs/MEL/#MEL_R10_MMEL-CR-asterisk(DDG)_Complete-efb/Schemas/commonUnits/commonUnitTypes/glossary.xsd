<xs:include schemaLocation="../../attributeTypes/generalAttrs.xsd"/>
<xs:include schemaLocation="../../basicDataTypes/basicDataInclude.xsd"/>
<xs:include schemaLocation="../../metadataTypes/effect.xsd"/>
<xs:import namespace="http://www.boeing.com/FTID-ML/Revision" schemaLocation="../../metadataTypes/revision.xsd"/>


<!-- Split from the Glossary.xsd to share the commone GlossaryListType with other front-matter schemas -->

<!--=====================================================-->
<!--  GlossaryList element definition -->
<!--=====================================================-->
<xs:complexType name="GlossaryListType">
    <xs:annotation>
        <xs:documentation>Container of glossary items</xs:documentation>
    </xs:annotation>

    <xs:sequence maxOccurs="unbounded">
        <xs:element name="Guide" type="ExtendedMixedContentType" minOccurs="0"/>
        <xs:element name="GlossaryItem" type="GlossaryItemType" maxOccurs="unbounded"/>
    </xs:sequence>

    <xs:attributeGroup ref="globalAttrGrp"/>
</xs:complexType>


<!--=====================================================-->
<!--  GlossaryItem element definition -->
<!--=====================================================-->
<xs:complexType name="GlossaryItemType">
    <xs:annotation>
        <xs:documentation>Container for individual Term/Definition</xs:documentation>
    </xs:annotation>

    <xs:sequence>
        <xs:element name="Term" type="ExtendedMixedContentType"/>
        <xs:element name="Definition" type="ExtendedMixedContentType" maxOccurs="unbounded"/>
        <xs:element name="GlossaryList" type="GlossaryListType" minOccurs="0"/>
    </xs:sequence>

    <xs:attributeGroup ref="globalAttrGrp"/>
</xs:complexType>


</xs:schema>
