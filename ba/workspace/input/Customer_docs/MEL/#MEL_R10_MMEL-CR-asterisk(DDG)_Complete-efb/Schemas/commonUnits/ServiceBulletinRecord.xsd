<xs:include schemaLocation="../attributeTypes/generalAttrs.xsd"/>
<xs:include schemaLocation="../basicDataTypes/basicDataInclude.xsd"/>
<xs:include schemaLocation="../metadataTypes/effect.xsd"/>
<xs:import namespace="http://www.boeing.com/FTID-ML/Revision" schemaLocation="../metadataTypes/revision.xsd"/>


<!--=====================================================-->
<!--  ServiceBulletinRecord element declaration -->
<!--=====================================================-->
<xs:element name="ServiceBulletinRecord" type="ServiceBulletinRecordType"/>


<!--=====================================================-->
<!--  ServiceBulletinRecord element definition -->
<!--=====================================================-->
<xs:complexType name="ServiceBulletinRecordType">
    <xs:annotation>
        <xs:documentation>Content-Unit for recording Service Bulletin history</xs:documentation>
    </xs:annotation>

    <xs:sequence>
        <xs:element name="Title" type="TitleType"/>
        <xs:choice maxOccurs="unbounded">
            <xs:group ref="TextGroupType"/>
        </xs:choice>
        <xs:element name="SBList" type="SBListType" minOccurs="0"/>
    </xs:sequence>

    <xs:attribute name="id" type="UIDType" use="required"/>
    <xs:attributeGroup ref="globalAttrGrp"/>
</xs:complexType>


<!--=====================================================-->
<!--  SBList element definition -->
<!--=====================================================-->
<xs:complexType name="SBListType">
    <xs:annotation>
        <xs:documentation>List of issued SB</xs:documentation>
    </xs:annotation>

    <xs:sequence>
        <xs:element name="SBItem" type="SBItemType"/>
    </xs:sequence>

</xs:complexType>


<!--=====================================================-->
<!--  SBItem element definition -->
<!--=====================================================-->
<xs:complexType name="SBItemType">
    <xs:annotation>
        <xs:documentation>Individual SB info</xs:documentation>
    </xs:annotation>

    <xs:sequence>
        <xs:element name="SBNo" type="SimpleMixedContentType"/>
        <xs:element name="SBTitle" type="SimpleMixedContentType"/>
        <xs:element name="SBDate" type="SimpleMixedContentType"/>
    </xs:sequence>

    <xs:attributeGroup ref="globalAttrGrp"/>
</xs:complexType>


</xs:schema>
