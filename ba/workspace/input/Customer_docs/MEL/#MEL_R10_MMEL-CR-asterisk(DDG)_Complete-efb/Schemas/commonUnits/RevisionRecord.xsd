<xs:include schemaLocation="../attributeTypes/generalAttrs.xsd"/>
<xs:include schemaLocation="../basicDataTypes/basicDataInclude.xsd"/>
<xs:include schemaLocation="../metadataTypes/effect.xsd"/>
<xs:import namespace="http://www.boeing.com/FTID-ML/Revision" schemaLocation="../metadataTypes/revision.xsd"/>
<xs:include schemaLocation="commonUnitTypes/fmTopic.xsd"/>


<!--=====================================================-->
<!--  RevisionRecord element declaration -->
<!--=====================================================-->
<xs:element name="RevisionRecord" type="RevisionRecordType"/>


<!--=====================================================-->
<!--  RevisionRecord element definition -->
<!--=====================================================-->
<xs:complexType name="RevisionRecordType">
    <xs:annotation>
        <xs:documentation>Content-Unit for recording Revision history</xs:documentation>
    </xs:annotation>

    <xs:sequence>
        <xs:element name="Title" type="TitleType" minOccurs="0"/>
        <xs:choice maxOccurs="unbounded">
            <xs:group ref="TextGroupType"/>
        </xs:choice>
        <xs:element name="FMtopic" type="FMtopicType" minOccurs="0" maxOccurs="unbounded"/>
        <xs:element name="HighlightList" type="HighlightListType" minOccurs="0" maxOccurs="unbounded"/>
    </xs:sequence>

    <xs:attribute name="id" type="UIDType" use="required"/>
    <xs:attributeGroup ref="globalAttrGrp"/>
</xs:complexType>


<!--=====================================================-->
<!--  HighlightList element definition -->
<!--=====================================================-->
<xs:complexType name="HighlightListType">
    <xs:annotation>
        <xs:documentation>List of revision highlights</xs:documentation>
    </xs:annotation>

    <xs:sequence>
        <xs:element name="Title" type="TitleType" minOccurs="0"/>
        <xs:element name="Para" type="ParaType" minOccurs="0" maxOccurs="unbounded"/>
        <xs:element name="HighlightItem" type="HighlightItemType" maxOccurs="unbounded"/>
    </xs:sequence>
</xs:complexType>


<!--=====================================================-->
<!--  HighlightItem element definition -->
<!--=====================================================-->
<xs:complexType name="HighlightItemType">
    <xs:annotation>
        <xs:documentation>An Item within a list of highlights</xs:documentation>
    </xs:annotation>

    <xs:sequence>
        <xs:element name="Title" type="TitleType" minOccurs="0"/>
        <xs:element name="Para" type="ParaType" minOccurs="0" maxOccurs="unbounded"/>
        <xs:element name="HighlightList" type="HighlightListType" minOccurs="0" maxOccurs="unbounded"/>
    </xs:sequence>

</xs:complexType>


</xs:schema>
