<xs:include schemaLocation="../attributeTypes/generalAttrs.xsd"/>
<xs:include schemaLocation="../attributeTypes/melAttrs.xsd"/>
<xs:include schemaLocation="../basicDataTypes/basicDataInclude.xsd"/>
<xs:include schemaLocation="../metadataTypes/effect.xsd"/>
<xs:import namespace="http://www.boeing.com/FTID-ML/Revision" schemaLocation="../metadataTypes/revision.xsd"/>
<xs:include schemaLocation="../proceduralTypes/dispatch.xsd"/>


<!--=====================================================-->
<!--  Root element declaration -->
<!--=====================================================-->
<xs:element name="MELItem" type="MELItemType"/>


<!--=====================================================-->
<!-- MELItem element definition -->
<!--=====================================================-->
<xs:complexType name="MELItemType">
    <xs:annotation>
        <xs:documentation>Content-Unit for a MEL-item</xs:documentation>
    </xs:annotation>

    <xs:sequence>
        <xs:element name="Effectivities" type="EffectivitiesType" minOccurs="0"/>
        <xs:element name="Title" type="TitleType"/>
        <xs:element name="DispatchCondition" type="DispatchConditionType" minOccurs="0" maxOccurs="unbounded"/>
        <xs:element name="MELSubItem" type="MELSubItemType" minOccurs="0" maxOccurs="unbounded"/>
    </xs:sequence>

    <xs:attribute name="itemNbr" type="itemNbrType" use="required"/>
    <xs:attribute name="id" type="UIDType" use="required"/>
    <xs:attribute name="optionalConfigIndicator" type="xs:string" fixed="***"/>
    <xs:attributeGroup ref="globalAttrGrp"/>
</xs:complexType>


<!--=====================================================-->
<!-- MELSubItem element definition -->
<!--=====================================================-->
<xs:complexType name="MELSubItemType">
    <xs:annotation>
        <xs:documentation>Top level element to start a MEL Sub-Item level.</xs:documentation>
    </xs:annotation>

    <xs:sequence>
        <xs:element name="Effectivities" type="EffectivitiesType" minOccurs="0"/>
        <xs:element name="Title" type="TitleType"/>
        <xs:element name="DispatchCondition" type="DispatchConditionType" minOccurs="0" maxOccurs="unbounded"/>
        <xs:element name="MELSubItem" type="MELSubItemType" minOccurs="0" maxOccurs="unbounded"/>
    </xs:sequence>

    <xs:attribute name="itemNbr" type="itemNbrType" use="required" />
    <xs:attribute name="optionalConfigIndicator" type="xs:string" fixed="***"/>
    <xs:attributeGroup ref="globalAttrGrp"/>
</xs:complexType>



</xs:schema>
