<xs:include schemaLocation="../attributeTypes/generalAttrs.xsd"/>
<xs:include schemaLocation="../basicDataTypes/basicDataInclude.xsd"/>
<xs:include schemaLocation="../proceduralTypes/proceduralInclude.xsd"/>
<xs:include schemaLocation="../metadataTypes/ataPOF.xsd" />
<xs:include schemaLocation="../metadataTypes/effect.xsd"/>
<xs:import namespace="http://www.boeing.com/FTID-ML/Revision" schemaLocation="../metadataTypes/revision.xsd"/>


<!--=====================================================-->
<!--  NonNormal Root element declaration -->
<!--=====================================================-->
<xs:element name="NonNormal" type="NonNormalType"/>


<!--=====================================================-->
<!-- NonNormal element definition -->
<!--=====================================================-->
<xs:complexType name="NonNormalType">
    <xs:annotation>
        <xs:documentation>Content-Unit for a non-normal procedural content type</xs:documentation>
    </xs:annotation>

    <xs:sequence>
        <xs:element name="Effectivities" type="EffectivitiesType" minOccurs="0"/>
        <xs:element name="Title" type="TitleType"/>
        <xs:element name="AdditionalTitles" type="AdditionalTitlesType" minOccurs="0"/>
        <xs:element name="POF" type="POFType"  minOccurs="0"/>
        <xs:element name="CheckListPreamble" type="CheckListPreambleType" minOccurs="0"/>
        <xs:choice minOccurs="0"  maxOccurs="unbounded">
            <xs:element name="ProcActionsGrp" type="ProcActionsGrpType"/>
            <xs:element name="ProcItem" type="ProcItemType"/>
        </xs:choice>
    </xs:sequence>

    <xs:attribute name="id" type="UIDType" use="required"/>
    <xs:attribute name="recall" type="YNType" use="optional"/>
    <xs:attribute name="end" type="YNType" use="optional"/>
    <xs:attributeGroup ref="globalAttrGrp"/>
</xs:complexType>


<!--=====================================================-->
<!--  CheckListPreamble element definition -->
<!--=====================================================-->
<xs:complexType name="CheckListPreambleType">
    <xs:annotation>
        <xs:documentation>Preamble information for a NonNormal checklist regarding its condition, objective, etc.</xs:documentation>
    </xs:annotation>

    <xs:choice maxOccurs="unbounded">
        <xs:element name="WarnCondition" type="WarnConditionType"/>
        <xs:element name="Objective" type="ObjectiveType"/>
        <xs:element name="Light" type="LightType"/>
    </xs:choice>
</xs:complexType>


<!--=====================================================-->
<!--  Objective element definition -->
<!--=====================================================-->
<xs:complexType name="ObjectiveType">
    <xs:annotation>
        <xs:documentation>Objectives when performing a NonNormal procedure</xs:documentation>
    </xs:annotation>

    <xs:choice minOccurs="0" maxOccurs="5">
        <xs:group ref="ShortTextGroupType"/>
    </xs:choice>

    <xs:attributeGroup ref="globalAttrGrp"/>
</xs:complexType>




</xs:schema>
