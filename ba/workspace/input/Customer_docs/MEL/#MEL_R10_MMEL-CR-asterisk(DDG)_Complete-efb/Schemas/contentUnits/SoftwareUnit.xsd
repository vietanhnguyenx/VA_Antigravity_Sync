<xs:include schemaLocation="../attributeTypes/generalAttrs.xsd"/>
<xs:include schemaLocation="../basicDataTypes/basicDataInclude.xsd"/>
<xs:include schemaLocation="../metadataTypes/effect.xsd"/>
<xs:import namespace="http://www.boeing.com/FTID-ML/Revision" schemaLocation="../metadataTypes/revision.xsd"/>



<!--=====================================================-->
<!--  Root element declaration -->
<!--=====================================================-->
<xs:element name="SoftwareUnit" type="SoftwareUnitType"/>


<!--=====================================================-->
<!-- SoftwareUnit element definition -->
<!--=====================================================-->
<xs:complexType name="SoftwareUnitType">
    <xs:annotation>
        <xs:documentation>Content Unit for a reference to a software application</xs:documentation>
    </xs:annotation>

    <xs:sequence>
        <xs:element name="Effectivities" type="EffectivitiesType" minOccurs="0"/>
        <xs:element name="Title" type="TitleType" minOccurs="0"/>
        <xs:choice minOccurs="0" maxOccurs="unbounded">
            <xs:group ref="TextCWNGroupType"/>
            <xs:element name="SoftwareRef" type="SoftwareRefType"/>
        </xs:choice>
    </xs:sequence>

    <xs:attribute name="id" type="UIDType" use="required"/>
    <xs:attributeGroup ref="globalAttrGrp"/>
</xs:complexType>


<!--=====================================================-->
<!-- SoftwareRef element definition -->
<!--=====================================================-->
<xs:complexType name="SoftwareRefType">
    <xs:annotation>
        <xs:documentation>SW Info and reference</xs:documentation>
    </xs:annotation>

    <xs:sequence>
        <xs:element name="Effectivities" type="EffectivitiesType" minOccurs="0"/>
        <xs:element ref="iLink" />
    </xs:sequence>

    <xs:attribute name="swType" type="xs:string" use="optional"/>
    <xs:attribute name="swSerialNo" type="xs:string" use="optional"/>
    <xs:attribute name="swReleaseNo" type="xs:string" use="optional"/>
    <xs:attribute name="swReleaseDate" type="xs:date" use="optional"/>
    <xs:attribute name="swOEM" type="xs:string" use="optional"/>
    <xs:attributeGroup ref="globalAttrGrp"/>
</xs:complexType>

</xs:schema>
