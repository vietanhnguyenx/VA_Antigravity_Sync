<xs:include schemaLocation="../attributeTypes/generalAttrs.xsd"/>
<xs:include schemaLocation="../basicDataTypes/basicDataInclude.xsd"/>
<xs:include schemaLocation="../metadataTypes/effect.xsd"/>
<xs:import namespace="http://www.boeing.com/FTID-ML/Revision" schemaLocation="../metadataTypes/revision.xsd"/>


<!--=====================================================-->
<!--  EICASList element declaration -->
<!--=====================================================-->
<xs:element name="EICASList" type="EICASListType"/>


<!--=====================================================-->
<!-- EICASList element definition -->
<!--=====================================================-->
<xs:complexType name="EICASListType">
    <xs:annotation>
        <xs:documentation>List of electronic (EICAS) messages</xs:documentation>
    </xs:annotation>

    <xs:sequence>
        <xs:element name="Effectivities" type="EffectivitiesType" minOccurs="0"/>
        <xs:element name="EICASListItem" type="EICASListItemType" maxOccurs="unbounded"/>
    </xs:sequence>

    <xs:attribute name="id" type="UIDType" use="required"/>
    <xs:attributeGroup ref="globalAttrGrp"/>
</xs:complexType>


<!--=====================================================-->
<!-- EICASListItem element definition -->
<!--=====================================================-->
<xs:complexType name="EICASListItemType">
    <xs:annotation>
        <xs:documentation>An EICAS item info</xs:documentation>
    </xs:annotation>

    <xs:sequence>
        <xs:element name="Effectivities" type="EffectivitiesType" minOccurs="0"/>
        <xs:element name="EICASMessage" type="EICASMessageType"/>
        <xs:element name="EICASLevelWithRefs" type="EICASLevelWithRefsType" minOccurs="0" maxOccurs="unbounded"/>
    </xs:sequence>

    <xs:attributeGroup ref="globalAttrGrp"/>
</xs:complexType>


<!--=====================================================-->
<!-- EICASMessage element definition -->
<!--=====================================================-->
<xs:complexType name="EICASMessageType" mixed="true">
    <xs:annotation>
        <xs:documentation>EICAS message description</xs:documentation>
    </xs:annotation>

    <xs:attributeGroup ref="globalAttrGrp"/>
</xs:complexType>


<!--=====================================================-->
<!-- EICASLevelWithRefs element definition -->
<!--=====================================================-->
<xs:complexType name="EICASLevelWithRefsType">
    <xs:annotation>
        <xs:documentation>An EICAS message level and its possible MMEL references</xs:documentation>
    </xs:annotation>

    <xs:sequence>
        <xs:element name="EICASLevel" type="EICASLevelType"/>
        <xs:element name="MMELItemRef" type="MMELItemRefType"  minOccurs="0"/>
    </xs:sequence>

</xs:complexType>


<!--=====================================================-->
<!-- EICASLevel element definition -->
<!--=====================================================-->
<xs:complexType name="EICASLevelType" mixed="true">
    <xs:annotation>
        <xs:documentation>EICAS level status</xs:documentation>
    </xs:annotation>

    <xs:attributeGroup ref="globalAttrGrp"/>
</xs:complexType>


<!--=====================================================-->
<!-- MMELItemRef element definition -->
<!--=====================================================-->
<xs:complexType name="MMELItemRefType">
    <xs:annotation>
        <xs:documentation>MMEL-item reference info</xs:documentation>
    </xs:annotation>

    <xs:choice minOccurs="0" maxOccurs="unbounded">
        <xs:element name="Para" type="ParaType" />
        <xs:element ref="iLink" />
    </xs:choice>
    <xs:attributeGroup ref="globalAttrGrp"/>
</xs:complexType>


</xs:schema>
