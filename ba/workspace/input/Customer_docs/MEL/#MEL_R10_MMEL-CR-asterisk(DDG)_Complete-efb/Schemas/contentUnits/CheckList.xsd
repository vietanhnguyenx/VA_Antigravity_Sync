<xs:include schemaLocation="../attributeTypes/generalAttrs.xsd"/>
<xs:include schemaLocation="../basicDataTypes/basicDataInclude.xsd"/>
<xs:import namespace="http://www.boeing.com/FTID-ML/Revision" schemaLocation="../metadataTypes/revision.xsd"/>
<xs:include schemaLocation="../metadataTypes/effect.xsd"/>
<xs:include schemaLocation="../metadataTypes/ataPOF.xsd"/>
<xs:include schemaLocation="../proceduralTypes/procMisc.xsd"/>
<xs:include schemaLocation="../proceduralTypes/action.xsd"/>


<!--=====================================================-->
<!--  CheckList element declaration -->
<!--=====================================================-->
<xs:element name="CheckList" type="CheckListType"/>


<!--=====================================================-->
<!-- CheckList element definition -->
<!--=====================================================-->
<xs:complexType name="CheckListType">
    <xs:annotation>
        <xs:documentation>Content-Unit for a CheckList list</xs:documentation>
    </xs:annotation>

    <xs:sequence>
        <xs:element name="Effectivities" type="EffectivitiesType" minOccurs="0"/>
        <xs:element name="Title" type="TitleType"/>
        <xs:element name="POF" type="POFType"  minOccurs="0"/>
        <xs:choice minOccurs="0" maxOccurs="unbounded">
            <xs:element name="Action" type="ActionType"/>
            <xs:element name="Command" type="CommandType"/>
            <xs:element name="GraphicSet" type="GraphicSetType"/>
        </xs:choice>
    </xs:sequence>

    <xs:attribute name="id" type="UIDType" use="required"/>
    <xs:attribute name="CLGroup" type="CLGroupType" default="Normal"/>
    <xs:attributeGroup ref="globalAttrGrp"/>
</xs:complexType>


<!--=====================================================-->
<!-- CLGroup attribute definition -->
<!--=====================================================-->
<xs:simpleType name="CLGroupType">
    <xs:annotation>
        <xs:documentation>Specify where check-list content type is derived from or for</xs:documentation>
    </xs:annotation>

    <xs:restriction base="xs:NMTOKEN">
        <xs:enumeration value="Normal"/>
        <xs:enumeration value="NonNormal"/>
        <xs:enumeration value="Emergency"/>
        <xs:enumeration value="na"/>
    </xs:restriction>
</xs:simpleType>


</xs:schema>
