<xs:include schemaLocation="../contentUnits/EICASRefsList.xsd" />



<!--=====================================================-->
<!--  EICASReferences element declaration -->
<!--=====================================================-->
<xs:element name="EICASReferences" type="EICASReferencesType"/>


<!--=====================================================-->
<!-- EICASReferences element definition -->
<!--=====================================================-->
<xs:complexType name="EICASReferencesType">
    <xs:annotation>
        <xs:documentation>Publish-Unit for EICAS references content</xs:documentation>
    </xs:annotation>

    <xs:sequence>
        <xs:element name="Title" type="TitleType" minOccurs="0" default="EICAS References Lists"/>
        <xs:element name="PUMetaData" type="PUMetaDataType"/>
        <xs:element ref="EICASList" maxOccurs="unbounded"/>
    </xs:sequence>

    <xs:attribute name="id" type="UIDType" use="required"/>
</xs:complexType>





