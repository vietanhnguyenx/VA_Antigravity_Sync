<xs:include schemaLocation="../attributeTypes/generalAttrs.xsd"/>
<xs:include schemaLocation="../basicDataTypes/basicDataInclude.xsd"/>
<xs:include schemaLocation="../metadataTypes/effect.xsd"/>
<xs:import namespace="http://www.boeing.com/FTID-ML/Revision" schemaLocation="../metadataTypes/revision.xsd"/>
<xs:include schemaLocation="../metadataTypes/publishMD.xsd" />
<xs:include schemaLocation="../commonUnits/BulletinRecord.xsd" />
<xs:include schemaLocation="../commonUnits/EffectCrossRefs.xsd" />
<xs:include schemaLocation="../commonUnits/Glossary.xsd" />
<xs:include schemaLocation="../commonUnits/Introduction.xsd" />
<xs:include schemaLocation="../commonUnits/RevisionNotice.xsd" />
<xs:include schemaLocation="../commonUnits/RevisionRecord.xsd" />
<xs:include schemaLocation="../commonUnits/ServiceBulletinRecord.xsd" />
<xs:include schemaLocation="../commonUnits/TitlePage.xsd" />


<!--=====================================================-->
<!--  FrontMatter (Publish-Unit) element declaration -->
<!--=====================================================-->
<xs:element name="FrontMatter" type="FrontMatterType"/>


<!--=====================================================-->
<!-- FrontMatter element definition -->
<!--=====================================================-->
<xs:complexType name="FrontMatterType">
    <xs:annotation>
        <xs:documentation>Publish-Unit for all front/back or miscelleous info or data units</xs:documentation>
    </xs:annotation>

    <xs:sequence>
        <xs:element name="PUMetaData" type="PUMetaDataType"/>
        <xs:choice minOccurs="0" maxOccurs="unbounded">
            <xs:element ref="iLink" />
            <xs:element ref="BulletinRecord" />
            <xs:element ref="EffectCrossRefs" />
            <xs:element ref="Glossary" />
            <xs:element ref="Introduction" />
            <xs:element ref="RevisionNotice" />
            <xs:element ref="RevisionRecord" />
            <xs:element ref="ServiceBulletinRecord" />
            <xs:element ref="TitlePage" />
        </xs:choice>
    </xs:sequence>

    <xs:attribute name="id" type="UIDType" use="required"/>
</xs:complexType>


</xs:schema>
