<xs:include schemaLocation="../attributeTypes/generalAttrs.xsd"/>
<xs:include schemaLocation="../attributeTypes/melAttrs.xsd"/>
<xs:include schemaLocation="../basicDataTypes/basicDataInclude.xsd"/>
<xs:include schemaLocation="../metadataTypes/effect.xsd"/>
<xs:import namespace="http://www.boeing.com/FTID-ML/Revision" schemaLocation="../metadataTypes/revision.xsd"/>
<xs:include schemaLocation="../metadataTypes/publishMD.xsd" />
<xs:include schemaLocation="../contentUnits/MELItem.xsd" />
<xs:include schemaLocation="../contentUnits/CDLItem.xsd" />



<!--=====================================================-->
<!--  Publish-Unit: DispatchItems element declaration -->
<!--=====================================================-->
<xs:element name="DispatchItems" type="DispatchItemsType">
    <xs:annotation>
        <xs:documentation>DispatchItems is a Publish-Unit of the FTID-ML Standard.  It consists of one or more MEL/CDL Content-Unit(s) to be published as a set.</xs:documentation>
    </xs:annotation>
</xs:element>

<!--=====================================================-->
<!-- DispatchItemsType element definition -->
<!--=====================================================-->
<xs:complexType name="DispatchItemsType">
    <xs:annotation>
        <xs:documentation>Top level type to define a complete publishable unit of MEL/CDL item(s).</xs:documentation>
    </xs:annotation>

    <xs:sequence>
        <xs:element name="PUMetaData" type="PUMetaDataType"/>
        <xs:choice minOccurs="0" maxOccurs="unbounded">
            <xs:element ref="MELItem" />
            <xs:element ref="CDLItem" />
            <xs:element ref="iLink" />
        </xs:choice>
    </xs:sequence>

    <xs:attribute name="id" type="UIDType" use="required"/>
</xs:complexType>



</xs:schema>
