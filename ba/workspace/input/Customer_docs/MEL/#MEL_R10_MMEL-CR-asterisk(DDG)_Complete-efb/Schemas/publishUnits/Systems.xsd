<xs:include schemaLocation="../attributeTypes/generalAttrs.xsd"/>
<xs:include schemaLocation="../basicDataTypes/basicDataInclude.xsd"/>
<xs:include schemaLocation="../metadataTypes/effect.xsd"/>
<xs:import namespace="http://www.boeing.com/FTID-ML/Revision" schemaLocation="../metadataTypes/revision.xsd"/>
<xs:include schemaLocation="../metadataTypes/ataSystems.xsd" />
<xs:include schemaLocation="../metadataTypes/publishMD.xsd" />
<xs:include schemaLocation="../contentUnits/SDSubject.xsd" />
<xs:include schemaLocation="../contentUnits/Operation.xsd" />
<xs:include schemaLocation="../contentUnits/Limitation.xsd" />

<!--=====================================================-->
<!--  Systems element declaration -->
<!--=====================================================-->
<xs:element name="Systems" type="SystemsType"/>


<!--=====================================================-->
<!-- SystemsDescription element definition -->
<!--=====================================================-->
<xs:complexType name="SystemsType">
    <xs:annotation>
        <xs:documentation>Publish-Unit for Systems related information</xs:documentation>
    </xs:annotation>

    <xs:sequence>
        <xs:element name="PUMetaData" type="PUMetaDataType"/>
        <xs:sequence>
            <xs:element name="Intro" type="IntroType" minOccurs="0"/>
            <xs:choice minOccurs="0" maxOccurs="unbounded">
                <xs:element ref="SDSubject" />
                <xs:element ref="Operation" />
                <xs:element ref="Limitation" />
                <xs:element ref="iLink" />
            </xs:choice>
        </xs:sequence> 
    </xs:sequence>

    <xs:attribute name="id" type="UIDType" use="required"/>
</xs:complexType>



</xs:schema>
