<Title>Angle of Attack (AOA) Sensors</Title>
<MELSubItem itemNbr="34-12-03-01">
<Title>AOA Resolvers</Title>
<DispatchCondition dispCondOptions="A" repairInterval="B" nbrInstalled="4" nbrRequired="2" maintIndicator="(M)" rev:revStatus="R" rev:revHighlight="Added&#xD;&#xA;new (M) indicator to provide procedures on how to verify AOA heaters and resolvers.">
<?FTID-rev start?>
<?FTID-rev end?>
<Title>
<?FTID-xref 1310006.2-34-12-03?>One Resolver For Each Sensor Operates Normally</Title>
<DispatchConditionRemarks>
<Para rev:revStatus="R" rev:revHighlight="Revised provisos to verify AOA heaters and resolvers.">
<?FTID-rev start?>May be inoperative provided: <?FTID-rev end?></Para>
<List listType="a.">
<ListItem>
<Para rev:revStatus="R" rev:revHighlight="Add new provisos to verify AOA heaters.">
<?FTID-rev start?>Both left and right AOA heaters are verified to operate normally.<?FTID-rev end?></Para>
</ListItem>
<ListItem>
<Para rev:revStatus="R" rev:revHighlight="EMPTY">
<?FTID-rev start?>One left AOA Resolver operates normally.<?FTID-rev end?></Para>
</ListItem>
<ListItem>
<Para rev:revStatus="R" rev:revHighlight="EMPTY">
<?FTID-rev start?>One right AOA Resolver operates normally<?FTID-rev end?></Para>
</ListItem>
</List>
</DispatchConditionRemarks>
<DispatchProcedure>
<MaintenanceProcedure rev:revStatus="R" rev:revHighlight="Added new (M) section to verify AOA heater system.">
<?FTID-rev start?>
<Para>Verify that both left and right AOA heater systems operate normally (AMM DDG 34-12-03)</Para>
<List listType="1.">
<ListItem>
<Para>Use the CMCF to run the following tests:</Para>
<List listType="A.">
<ListItem>
<Para>Left Air Data Heater test</Para>
</ListItem>
<ListItem>
<Para>Right Air Data Heater test</Para>
</ListItem>
</List>
</ListItem>
</List>
<?FTID-rev end?>
</MaintenanceProcedure>
</DispatchProcedure>
</DispatchCondition>
<DispatchCondition dispCondOptions="C" repairInterval="C" nbrInstalled="4" nbrRequired="3" maintIndicator="(M)" rev:revStatus="R" rev:revHighlight="Added item">
<Title>One Resolver Inoperative</Title>
<DispatchConditionRemarks>
<Para>One may be inoperative provided both left and right AOA heaters are verified to operate normally </Para>
</DispatchConditionRemarks>
<?FTID-rev start?>
<DispatchProcedure>
<MaintenanceProcedure>
