<MELItem itemNbr="24-71-01" id="X-BOEING:FTID:81205.787.DDG.CU.MEL.2-24-71-01.1.2-24-71-01">
<Title>Remote Power Distribution Unit (RPDU) Channels</Title>
<MELSubItem itemNbr="24-71-01-01">
<Title>Standard RPDU Channels</Title>
<DispatchCondition dispCondOptions="A" repairInterval="C" nbrInstalled="26" nbrRequired="13">
<Title>Gateway RPDU Channels Operate Normally</Title>
<DispatchConditionRemarks>
<Para>One channel in each standard RPDU may be inoperative provided gateway RPDU channels operate normally.</Para>
</DispatchConditionRemarks>
</DispatchCondition>
<DispatchCondition dispCondOptions="B" repairInterval="B" nbrInstalled="26" nbrRequired="22">
<Title>Associated Gateway RPDU Channels Inoperative</Title>
<DispatchConditionRemarks>
<Para>One channel in each standard RPDU associated with an inoperative gateway RPDU channel may be inoperative.</Para>
</DispatchConditionRemarks>
<DispatchProcedure>
