<MELItem itemNbr="22-11-08" id="X-BOEING:FTID:81205.787.DDG.CU.MEL.2-22-11-08.1.2-22-11-08">
<Title>Control Wheel Autopilot Disconnect Switches</Title>
<DispatchCondition dispCondOptions="A" repairInterval="C" nbrInstalled="2" nbrRequired="1">
<Title>Autopilot Not Used Below 1,500 ft AGL</Title>
<DispatchConditionRemarks>
<Para>One may be inoperative provided:</Para>
<List listType="a.">
<ListItem>
<Para>Autopilot is not used below 1,500 feet AGL.</Para>
</ListItem>
<ListItem>
<Para>Approach minimums do not require the use of the autopilot.</Para>
</ListItem>
</List>
</DispatchConditionRemarks>
<DispatchProcedure>
<OperationNote>
<List listType="1.">
<ListItem>
<Para>Maximum landing capability is CAT I.</Para>
</ListItem>
<ListItem>
<Para>RNP AR, LVO Approach and/or Autoland operations are not to be conducted.</Para>
</ListItem>
</List>
</OperationNote>
</DispatchProcedure>
</DispatchCondition>
<DispatchCondition dispCondOptions="B" repairInterval="B" nbrInstalled="2" nbrRequired="0">
<Title>Autopilot Not Used</Title>
<DispatchConditionRemarks>
<Para>May be inoperative provided:</Para>
<List listType="a.">
<ListItem>
<Para>Autopilot is not used.</Para>
</ListItem>
<ListItem>
<Para>Approach minimums do not require use of the autopilot.</Para>
</ListItem>
<ListItem>
<Para>Number of flight segments and segment duration is acceptable to flight crew.</Para>
</ListItem>
<ListItem>
<Para>Enroute operations do not require use of the autopilot.</Para>
</ListItem>
</List>
</DispatchConditionRemarks>
<DispatchProcedure>
<OperationNote>
<List listType="1.">
<ListItem>
<Para>EDTO and RVSM operations are not to be conducted.</Para>
</ListItem>
<ListItem>
<Para>RNP AR, LVO Approach and/or Autoland operations are not to be conducted.</Para>
</ListItem>
<ListItem>
<Para>Maximum landing capability is CAT I.</Para>
</ListItem>
</List>
</OperationNote>
</DispatchProcedure>
</DispatchCondition>
</MELItem>
</DispatchItems>