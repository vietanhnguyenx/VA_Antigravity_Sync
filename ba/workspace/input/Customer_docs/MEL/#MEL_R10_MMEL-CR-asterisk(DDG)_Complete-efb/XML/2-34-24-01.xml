<MELItem itemNbr="34-24-01" id="X-BOEING:FTID:81205.787.DDG.CU.MEL.2-34-24-01.1.2-34-24-01">
<Title>Integrated Standby Flight Display (ISFD)</Title>
<MELSubItem itemNbr="34-24-01-01">
<Title>Attitude Indication</Title>
<DispatchCondition repairInterval="B" nbrInstalled="1" nbrRequired="0">
<DispatchConditionRemarks>
<Para>May be inoperative provided:</Para>
<List listType="a.">
<ListItem>
<Para>Operations are conducted in day VMC only.</Para>
</ListItem>
<ListItem>
<Para>Operations are not conducted into known or forecast over-the-top conditions. </Para>
</ListItem>
</List>
</DispatchConditionRemarks>
</DispatchCondition>
</MELSubItem>
<MELSubItem itemNbr="34-24-01-02">
<Title>Airspeed Indication (*)</Title>
<DispatchCondition repairInterval="B" nbrInstalled="1" nbrRequired="0">
<DispatchConditionRemarks>
<Para>May be inoperative provided:</Para>
<List listType="a.">
<ListItem>
<Para>Left and right pitot air data modules operate normally.</Para>
</ListItem>
<ListItem>
<Para>Left and right pitot probe heater systems operate normally.</Para>
</ListItem>
<ListItem>
<Para>Left and right static air data modules operate normally.</Para>
</ListItem>
<ListItem>
<Para>AIR DATA/ATT instrument source switches operate normally.</Para>
</ListItem>
</List>
</DispatchConditionRemarks>
<DispatchProcedure>
<OperationNote>
<Para>Altitude differences may be noted between the ISFD altimeter indication and the primary displays, particularly at higher speeds and altitudes.  </Para>
</OperationNote>
</DispatchProcedure>
</DispatchCondition>
</MELSubItem>
<MELSubItem itemNbr="34-24-01-03">
<Title>Approach Mode (*)</Title>
<DispatchCondition repairInterval="C" nbrInstalled="1" nbrRequired="0">
<DispatchConditionRemarks>
<Para>May be inoperative.</Para>
</DispatchConditionRemarks>
</DispatchCondition>
</MELSubItem>
<MELSubItem itemNbr="34-24-01-04">
<Title>Heading Display (*)</Title>
<DispatchCondition repairInterval="B" nbrInstalled="1" nbrRequired="0">
<DispatchConditionRemarks>
<Para>May be inoperative provided non-stabilized magnetic compass (standby) operates normally.</Para>
</DispatchConditionRemarks>
</DispatchCondition>
</MELSubItem>
<MELSubItem itemNbr="34-24-01-05">
<Title>Switch Lights (*)</Title>
<DispatchCondition repairInterval="C" nbrInstalled="5" nbrRequired="0">
<DispatchConditionRemarks>
<Para>One or more may be inoperative.</Para>
</DispatchConditionRemarks>
</DispatchCondition>
</MELSubItem>
</MELItem>
