<MELItem itemNbr="31-61-07" id="X-BOEING:FTID:81205.787.DDG.CU.MEL.2-31-61-07.1.2-31-61-07">
<Title>Instrument Source (AIR DATA/ATT) Selector Switches</Title>
<MELSubItem itemNbr="31-61-07-01">
<Title>ALTN Position</Title>
<DispatchCondition repairInterval="C" nbrInstalled="2" nbrRequired="1" maintIndicator="(M)">
<DispatchConditionRemarks>
<Para>One may be inoperative provided: </Para>
<List listType="a.">
<ListItem>
<Para>Opposite AIR DATA/ATT switch is verified to operate normally.</Para>
</ListItem>
<ListItem>
<Para>Associated selector switch remains in AUTO position.</Para>
</ListItem>
</List>
</DispatchConditionRemarks>
<DispatchProcedure>
<MaintenanceProcedure>
<Para>Verify opposite AIR DATA/ATT selector operates normally (AMM DDG 31-61-07). </Para>
<List listType="1.">
<ListItem>
<Para>Set AIR DATA/ATT selector to the ALTN position.</Para>
<List listType="A.">
<ListItem>
<Para>Confirm the appropriate ALTN ATTITUDE CAPT or ALTN ATTITUDE  FO advisory message is displayed.</Para>
</ListItem>
<ListItem>
<Para>Confirm the SGL SOURCE ATTITUDE advisory message is not displayed.</Para>
</ListItem>
<ListItem>
<Para>Confirm that AOA SPD appears in amber below the associated PFD speed tape.</Para>
</ListItem>
<ListItem>
<Para>Confirm that GPS ALT appears in amber below the associated PFD altitude tape.</Para>
</ListItem>
</List>
</ListItem>
<ListItem>
<Para>Set the AIR DATA/ATT selector to the AUTO position.</Para>
<List listType="A.">
<ListItem>
<Para>Confirm the advisory messages and PFD indications are no longer displayed.</Para>
</ListItem>
</List>
</ListItem>
</List>
</MaintenanceProcedure>
</DispatchProcedure>
</DispatchCondition>
</MELSubItem>
</MELItem>
</DispatchItems>