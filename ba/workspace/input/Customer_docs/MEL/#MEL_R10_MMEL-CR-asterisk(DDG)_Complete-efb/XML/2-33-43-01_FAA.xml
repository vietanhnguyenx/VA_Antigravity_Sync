<Title>Position Lights</Title>
<DispatchCondition dispCondOptions="A" repairInterval="C" nbrInstalled="8" nbrRequired="4">
<Title>All Operations (*)</Title>
<DispatchConditionRemarks>
<Para>May be inoperative provided:</Para>
<List listType="a.">
<ListItem>
<Para>One red wingtip light operates normally.</Para>
</ListItem>
<ListItem>
<Para>One green wingtip light operates normally.</Para>
</ListItem>
<ListItem>
<Para>For one or both white tailcone lights inoperative, both white rear wingtip lights  operate normally.</Para>
</ListItem>
<ListItem>
<Para>For one or both white rear wingtip lights inoperative, both white tailcone lights operate normally.</Para>
</ListItem>
</List>
</DispatchConditionRemarks>
</DispatchCondition>
<DispatchCondition dispCondOptions="B" repairInterval="C" nbrInstalled="8" nbrRequired="0">
<Title>Day Operations (*)</Title>
<DispatchConditionRemarks>
<Para>May be inoperative between sunrise and sunset.</Para>
</DispatchConditionRemarks>
</DispatchCondition>
