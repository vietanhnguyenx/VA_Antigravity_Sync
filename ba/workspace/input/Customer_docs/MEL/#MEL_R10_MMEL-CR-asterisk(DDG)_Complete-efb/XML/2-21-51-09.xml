<MELItem itemNbr="21-51-09" id="X-BOEING:FTID:81205.787.DDG.CU.MEL.2-21-51-09.1.2-21-51-09">
<Title>Pack Control Unit (PCU) Channels</Title>
<MELSubItem itemNbr="21-51-09-01">
<Title>Left PCU Channels</Title>
<DispatchCondition dispCondOptions="A" repairInterval="C" nbrInstalled="2" nbrRequired="1">
<Title>Left Air Conditioning Pack Operates</Title>
<DispatchConditionRemarks>
<Para>One may be inoperative.</Para>
</DispatchConditionRemarks>
</DispatchCondition>
<DispatchCondition dispCondOptions="B" repairInterval="C" nbrInstalled="2" nbrRequired="0">
<Title>Left Air Conditioning Pack Considered Inoperative</Title>
<DispatchConditionRemarks>
<Para>May be inoperative provided:</Para>
<List listType="a.">
<ListItem>
<Para>At least one right PCU channel operates normally.</Para>
</ListItem>
<ListItem>
<Para>Left air conditioning pack is considered inoperative.</Para>
</ListItem>
</List>
</DispatchConditionRemarks>
<Note>
<Para>The airplane must also be dispatched using MEL item 21-52-01.</Para>
</Note>
</DispatchCondition>
</MELSubItem>
<MELSubItem itemNbr="21-51-09-02">
<Title>Right PCU Channels</Title>
<DispatchCondition dispCondOptions="A" repairInterval="C" nbrInstalled="2" nbrRequired="1">
<Title>Right Air Conditioning Pack Operates</Title>
<DispatchConditionRemarks>
<Para>One may be inoperative.</Para>
</DispatchConditionRemarks>
</DispatchCondition>
<DispatchCondition dispCondOptions="B" repairInterval="C" nbrInstalled="2" nbrRequired="0">
<Title>Right Air Conditioning Pack Considered Inoperative</Title>
<DispatchConditionRemarks>
<Para>May be inoperative provided:</Para>
<List listType="a.">
<ListItem>
<Para>At least one left PCU channel operates normally.</Para>
</ListItem>
<ListItem>
<Para>Right air conditioning pack is considered inoperative.</Para>
</ListItem>
</List>
</DispatchConditionRemarks>
<Note>
<Para>The airplane must also be dispatched using MEL item 21-52-01.</Para>
</Note>
</DispatchCondition>
</MELSubItem>
</MELItem>
