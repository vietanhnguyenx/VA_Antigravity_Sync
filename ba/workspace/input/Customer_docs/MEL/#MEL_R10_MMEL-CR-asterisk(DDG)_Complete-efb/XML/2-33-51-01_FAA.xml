<?FTID-rev start?>
<?FTID-rev end?>
<DispatchConditionRemarks>
<Para>One cross-aisle overhead emergency light may be inoperative at each passenger entry door pair.</Para>
</DispatchConditionRemarks>
</DispatchCondition>
