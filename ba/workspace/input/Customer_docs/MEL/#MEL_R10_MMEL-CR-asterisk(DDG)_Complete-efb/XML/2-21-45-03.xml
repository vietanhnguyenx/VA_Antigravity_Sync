<MELItem itemNbr="21-45-03" id="X-BOEING:FTID:81205.787.DDG.CU.MEL.2-21-45-03.1.2-21-45-03">
<Title>
<?FTID-xref 1280007.2-21-45-03?>Galley Area Duct Heaters</Title>
<DispatchCondition repairInterval="C" nbrInstalled="-" nbrRequired="0" maintIndicator="(M)">
<DispatchConditionRemarks>
<Para>May be inoperative deactivated.</Para>
</DispatchConditionRemarks>
<DispatchProcedure>
<MaintenanceProcedure>
<Para>Deactivate the inoperative galley heater (AMM DDG 21-45-03).</Para>
<List listType="1.">
<ListItem>
<Para>For forward galley heater inoperative:</Para>
<List listType="A.">
<ListItem>
<Para>Using a flight deck multi-function display only, open circuit breaker HEATER-GALLEY FWD and lock with an INOP tag.</Para>
</ListItem>
<ListItem>
<Para>Gain access to forward galley heater.</Para>
</ListItem>
<ListItem>
<Para>Disconnect, cap and stow electrical connector to forward galley heater.</Para>
</ListItem>
</List>
</ListItem>
<ListItem>
<Para>For mid galley heater inoperative:</Para>
<List listType="A.">
<ListItem>
<Para>Using a flight deck multi-function display only, open the inoperative heater circuit breaker and lock with an INOP tag:</Para>
<List listType="1)">
<ListItem>
<Para>HEATER-GALLEY 	MID 1</Para>
</ListItem>
<ListItem>
<Para>HEATER-GALLEY 	MID 2</Para>
</ListItem>
<ListItem>
<Para>HEATER-GALLEY 	MID 3</Para>
</ListItem>
<ListItem rev:revStatus="R" rev:revHighlight="Added missing circuit breaker reference for accuracy.">
<Para>HEATER-GALLEY MID 4</Para>
<?FTID-rev start?>
<?FTID-rev end?>
</ListItem>
<ListItem rev:revStatus="R" rev:revHighlight="Added missing circuit breaker reference for accuracy.">
<Para>HEATER-GALLEY MID 5</Para>
<?FTID-rev start?>
<?FTID-rev end?>
</ListItem>
<ListItem rev:revStatus="R" rev:revHighlight="Added missing circuit breaker reference for accuracy.">
<Para>HEATER-GALLEY MID 6</Para>
<?FTID-rev start?>
<?FTID-rev end?>
</ListItem>
</List>
</ListItem>
<ListItem>
<Para>Gain access to mid galley heater.</Para>
</ListItem>
<ListItem>
<Para>Disconnect, cap and stow electrical connector to mid galley heater.</Para>
</ListItem>
</List>
</ListItem>
<ListItem>
<Para>For aft galley heater inoperative:</Para>
<List listType="A.">
<ListItem>
<Para>Using a flight deck multi-function display only, open the inoperative heater circuit breaker and lock with an INOP tag:</Para>
<List listType="1)">
<ListItem>
<Para>HEATER-GALLEY 	AFT 1</Para>
</ListItem>
<ListItem>
<Para>HEATER-GALLEY 	AFT 2</Para>
</ListItem>
</List>
</ListItem>
<ListItem>
<Para>Gain access to aft galley heater.</Para>
</ListItem>
<ListItem>
<Para>Disconnect, cap and stow electrical connector to aft galley heater.</Para>
</ListItem>
</List>
</ListItem>
</List>
</MaintenanceProcedure>
</DispatchProcedure>
