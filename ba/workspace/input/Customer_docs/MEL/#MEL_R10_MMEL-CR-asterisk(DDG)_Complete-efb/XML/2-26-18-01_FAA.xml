<MELItem itemNbr="26-18-01" id="X-BOEING:FTID:81205.787.DDG.CU.MEL.2-26-18-01.1.2-26-18-01_FAA">
<Title>Duct Leak Overheat Detection Systems (*)</Title>
<DispatchCondition repairInterval="C" nbrInstalled="2" nbrRequired="1">
<DispatchConditionRemarks>
<Para>May be inoperative provided:</Para>
<List listType="a.">
<ListItem>
<Para>Associated engine anti-ice control switch remains OFF.</Para>
</ListItem>
<ListItem>
<Para>Airplane is not operated in known or forecast icing conditions.</Para>
</ListItem>
<ListItem>
<Para>EDTO beyond 120 minutes is not conducted.</Para>
</ListItem>
</List>
</DispatchConditionRemarks>
</DispatchCondition>
<MELSubItem itemNbr="26-18-01-01">
<Title>Duct Leak Overheat Detection Channels (*)</Title>
<DispatchCondition repairInterval="C" nbrInstalled="4" nbrRequired="2">
<DispatchConditionRemarks>
<Para>One channel per engine may be inoperative.</Para>
</DispatchConditionRemarks>
</DispatchCondition>
</MELSubItem>
