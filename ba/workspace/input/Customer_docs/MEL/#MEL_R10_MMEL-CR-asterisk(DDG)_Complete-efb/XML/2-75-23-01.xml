<MELItem itemNbr="75-23-01" id="X-BOEING:FTID:81205.787.DDG.CU.MEL.2-75-23-01.1.2-75-23-01">
<Title>Core Compartment Cooling (CCC) Valves (GE)</Title>
<DispatchCondition repairInterval="C" nbrInstalled="2" nbrRequired="0" maintIndicator="(M)">
<DispatchConditionRemarks>
<Para>May be inoperative locked open.</Para>
</DispatchConditionRemarks>
<DispatchProcedure>
<MaintenanceProcedure>
<Para>Lock the inoperative core compartment cooling (CCC) valve in the open position (AMM DDG 75-23-01).</Para>
<List listType="1.">
<ListItem>
<Para>Retract and deactivate the leading edge slats.</Para>
</ListItem>
<ListItem>
<Para>Deactivate the associated engine thrust reverser for ground maintenance.</Para>
</ListItem>
<ListItem>
<Para>Gain access to the CCC valve.</Para>
</ListItem>
<ListItem>
<Para>Lock the associated CCC valve in the open position.</Para>
</ListItem>
<ListItem>
<Para>Activate the associated engine thrust reverser after ground maintenance.</Para>
</ListItem>
<ListItem>
<Para>Activate the leading edge slats.</Para>
</ListItem>
</List>
</MaintenanceProcedure>
</DispatchProcedure>
</DispatchCondition>
</MELItem>
</DispatchItems>