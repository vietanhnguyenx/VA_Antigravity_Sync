<MELItem itemNbr="32-51-02" id="X-BOEING:FTID:81205.787.DDG.CU.MEL.2-32-51-02.1.2-32-51-02">
<Title>Nose Wheel Tillers</Title>
<MELSubItem itemNbr="32-51-02-01">
<Title>Left Tiller</Title>
<DispatchCondition repairInterval="C" nbrInstalled="1" nbrRequired="0" opsIndicator="(O)">
<DispatchConditionRemarks>
<Para>May be inoperative provided</Para>
<List listType="a.">
<ListItem>
<Para>Right tiller operates normally.</Para>
</ListItem>
<ListItem>
<Para>Alternate procedures are established and used.</Para>
</ListItem>
</List>
</DispatchConditionRemarks>
<DispatchProcedure>
<OperationProcedure>
<Para>Use right tiller as required to steer airplane on ground.</Para>
</OperationProcedure>
</DispatchProcedure>
</DispatchCondition>
</MELSubItem>
<MELSubItem itemNbr="32-51-02-02">
<Title>Right Tiller</Title>
<DispatchCondition dispCondOptions="A" repairInterval="C" nbrInstalled="1" nbrRequired="0" opsIndicator="(O)">
<Title>Alternate Procedures Used</Title>
<DispatchConditionRemarks>
<Para>May be inoperative provided:</Para>
<List listType="a.">
<ListItem>
<Para>Left tiller operates normally.</Para>
</ListItem>
<ListItem>
<Para>Alternate procedures are established and used.</Para>
</ListItem>
</List>
</DispatchConditionRemarks>
<DispatchProcedure>
<OperationProcedure>
<Para>Use left tiller as required to steer airplane on ground.</Para>
</OperationProcedure>
</DispatchProcedure>
</DispatchCondition>
