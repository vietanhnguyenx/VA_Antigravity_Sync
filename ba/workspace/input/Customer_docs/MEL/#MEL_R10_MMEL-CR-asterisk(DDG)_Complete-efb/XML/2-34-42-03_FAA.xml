<MELItem itemNbr="34-42-03" id="X-BOEING:FTID:81205.787.DDG.CU.MEL.2-34-42-03.1.2-34-42-03_FAA">
<Title>ATC Transponder/Automatic Altitude Reporting Systems</Title>
<DispatchCondition dispCondOptions="A" repairInterval="D" nbrInstalled="2" nbrRequired="1">
<Title>One Inoperative (*)</Title>
<DispatchConditionRemarks>
<Para>One may be inoperative.</Para>
</DispatchConditionRemarks>
</DispatchCondition>
<DispatchCondition dispCondOptions="B" repairInterval="B" nbrInstalled="2" nbrRequired="0">
<Title>
<?FTID-xref 1349465.2-34-42-03_FAA?>Both Inoperative</Title>
<DispatchConditionRemarks>
<Para>May be inoperative provided:</Para>
<List listType="a.">
<ListItem>
<Para>Enroute operations do not require its use.</Para>
</ListItem>
<ListItem>
<Para>Prior to flight, approval is obtained from ATC facilities having jurisdiction over the planned route of flight.</Para>
</ListItem>
<ListItem>
<Para>Flight is planned below RVSM airspace.</Para>
</ListItem>
</List>
</DispatchConditionRemarks>
<Note>
<Para>The ADS-B Out data will be inoperative. The airplane must also be dispatched using MEL item 34-42-06-01.</Para>
</Note>
<Note rev:revStatus="R" rev:revHighlight="Added new note to provide dispatch guidance that TCAS system will also be inoperative.">
<?FTID-rev start?>
<Para>The TCAS will be inoperative and TCAS L/R status messages will be displayed. The airplane must also be dispatched using MEL item 34-42-02.</Para>
<?FTID-rev end?>
</Note>
<DispatchProcedure>
<OperationNote>
<List listType="1.">
<ListItem>
<Para>RVSM and EDTO operations are not to be conducted.</Para>
</ListItem>
<ListItem>
<Para>Contact OCC Dispatch to confirm that ATC approval has been obtained for the planned flight.</Para>
</ListItem>
</List>
</OperationNote>
</DispatchProcedure>
</DispatchCondition>
<MELSubItem itemNbr="34-42-03-01">
<Title>Elementary and Enhanced Downlink Aircraft Reportable Parameters</Title>
<DispatchCondition repairInterval="A" nbrInstalled="2" nbrRequired="0">
<DispatchConditionRemarks>
<Para>May be inoperative provided:</Para>
<List listType="a.">
<ListItem>
<Para>Enroute operations do not require its use.</Para>
</ListItem>
<ListItem>
<Para>Repairs are made prior to completion of next heavy maintenance visit.</Para>
</ListItem>
</List>
</DispatchConditionRemarks>
</DispatchCondition>
</MELSubItem>
</MELItem>
