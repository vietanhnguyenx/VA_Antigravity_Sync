<MELItem itemNbr="23-51-01" id="X-BOEING:FTID:81205.787.DDG.CU.MEL.2-23-51-01.1.2-23-51-01_FAA">
<Title>Audio Control Panels (ACP)</Title>
<MELSubItem itemNbr="23-51-01-01">
<Title>First Officer’s Audio Control Panel</Title>
<DispatchCondition repairInterval="C" nbrInstalled="1" nbrRequired="0" opsIndicator="(O)">
<DispatchConditionRemarks>
<Para>First officer’s audio control panel may be inoperative provided first observer’s audio control panel operates normally.</Para>
<Note>
<Para>Any function that operates normally may be used.</Para>
</Note>
</DispatchConditionRemarks>
<Note>
<Para>See MEL item 25-11-02 for other equipment associated with the first observer seat.</Para>
</Note>
<DispatchProcedure>
<MaintenanceNote>
<Para>The audio control panels are interchangeable.</Para>
</MaintenanceNote>
<OperationProcedure>
<Para>Set the aft aisle stand OBS AUDIO selector to F/O.</Para>
<Note>
<Para>If airplane is powered only by standby power or battery power, the flight interphone will not operate</Para>
</Note>
</OperationProcedure>
</DispatchProcedure>
</DispatchCondition>
</MELSubItem>
<MELSubItem itemNbr="23-51-01-02">
<Title>First Observer’s Audio Control Panel</Title>
<DispatchCondition repairInterval="A" nbrInstalled="1" nbrRequired="0">
<DispatchConditionRemarks>
<Para>May be inoperative provided:</Para>
<List listType="a.">
<ListItem>
<Para>First Officer’s audio control panel operates normally.</Para>
</ListItem>
<ListItem>
<Para>Repairs are made within two flight days.</Para>
</ListItem>
</List>
<Note>
<Para>Any function that operates normally may be used.</Para>
</Note>
</DispatchConditionRemarks>
<Note>
<Para>See MEL item 25-11-02 for other equipment associated with the first observer seat.</Para>
</Note>
<DispatchProcedure>
<MaintenanceNote>
<Para>The audio control panels are interchangeable.</Para>
</MaintenanceNote>
</DispatchProcedure>
</DispatchCondition>
</MELSubItem>
<MELSubItem itemNbr="23-51-01-03">
<Title>Network Channels</Title>
<DispatchCondition dispCondOptions="A" repairInterval="C" nbrInstalled="4" nbrRequired="2">
<Title>Captain and First Officer (*)</Title>
<DispatchConditionRemarks>
<Para>One may be inoperative for each audio control panel.</Para>
</DispatchConditionRemarks>
</DispatchCondition>
<DispatchCondition dispCondOptions="B" repairInterval="D" nbrInstalled="2" nbrRequired="1">
<Title>First Observer (*)</Title>
<DispatchConditionRemarks>
<Para>One may be inoperative.</Para>
</DispatchConditionRemarks>
</DispatchCondition>
</MELSubItem>
