<MELItem itemNbr="23-51-03" id="X-BOEING:FTID:81205.787.DDG.CU.MEL.2-23-51-03.1.2-23-51-03_FAA">
<Title>Flight Deck Headsets/Headphones</Title>
<DispatchCondition repairInterval="D" nbrInstalled="4" nbrRequired="2">
<DispatchConditionRemarks>
<Para>Any in excess of one for each required crew member on flight deck duty may be inoperative or missing.</Para>
<Note>
<Para>Required one more Headsets/Headphone for the CAAV inspector for the performance of official duties.</Para>
</Note>
</DispatchConditionRemarks>
</DispatchCondition>
<MELSubItem itemNbr="23-51-03-01">
<Title>Headset Boom Microphones (*)</Title>
<DispatchCondition repairInterval="A" nbrInstalled="3" nbrRequired="0">
<DispatchConditionRemarks>
<Para>May be inoperative provided:</Para>
<List listType="a.">
<ListItem>
<Para>Associated hand microphone is installed and operates normally.</Para>
</ListItem>
<ListItem>
<Para>Repairs are made within three flight days.</Para>
</ListItem>
</List>
</DispatchConditionRemarks>
</DispatchCondition>
</MELSubItem>
<MELSubItem itemNbr="23-51-03-02">
<Title>Headset Earphones/Headphones (*)</Title>
<DispatchCondition repairInterval="C" nbrInstalled="4" nbrRequired="2">
<DispatchConditionRemarks>
<Para>Captain’s and first officer’s earphones/headphones must be operative.</Para>
<Note>
<Para>Required one more Headsets/Headphone for the CAAV inspector for the performance of official duties.</Para>
</Note>
</DispatchConditionRemarks>
</DispatchCondition>
</MELSubItem>
</MELItem>
</DispatchItems>