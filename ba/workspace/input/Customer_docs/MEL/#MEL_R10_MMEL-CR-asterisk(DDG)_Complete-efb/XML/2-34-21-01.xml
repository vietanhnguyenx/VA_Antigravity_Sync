<MELItem itemNbr="34-21-01" id="X-BOEING:FTID:81205.787.DDG.CU.MEL.34.1.2-34-21-01">
<Title />
<MELSubItem itemNbr="34-21-01-01">
<Title>Inertial Reference Units (IRUs)</Title>
<DispatchCondition repairInterval="C" nbrInstalled="2" nbrRequired="1" maintIndicator="(M)">
<DispatchConditionRemarks>
<Para>One may be inoperative provided:</Para>
<List listType="a.">
<ListItem>
<Para>Inoperative IRU is deactivated.</Para>
</ListItem>
<ListItem>
<Para>AHRUs operate normally.</Para>
</ListItem>
<ListItem>
<Para>At least one GPS operates normally.</Para>
</ListItem>
</List>
</DispatchConditionRemarks>
<DispatchProcedure>
<MaintenanceProcedure>
<Para>Deactivate the inoperative IRU (AMM DDG 34-21-01).</Para>
<List listType="1.">
<ListItem>
<Para>For left IRU inoperative:</Para>
<List listType="A.">
<ListItem>
<Para>Using a flight deck multi-function display only, open circuit breaker IRU-L and lock with an INOP tag.</Para>
</ListItem>
<ListItem>
<Para>Open and collar P300 panel IRU BATTERY-L circuit breaker. </Para>
</ListItem>
</List>
</ListItem>
<ListItem>
<Para>For right IRU inoperative:</Para>
<List listType="A.">
<ListItem>
<Para>Using a flight deck multi-function display only, open circuit breaker IRU-R and lock with an INOP tag.</Para>
</ListItem>
<ListItem>
<Para>Open and collar P300 panel IRU BATTERY-R circuit breaker. </Para>
</ListItem>
</List>
</ListItem>
</List>
</MaintenanceProcedure>
<OperationNote>
<Para>Associated IRS switch should be in the ON position.</Para>
</OperationNote>
</DispatchProcedure>
</DispatchCondition>
<MELSubItem itemNbr="34-21-01-01-01">
<Title>ON BAT Light</Title>
<DispatchCondition repairInterval="C" nbrInstalled="1" nbrRequired="0" />
</MELSubItem>
</MELSubItem>
<MELSubItem itemNbr="34-21-01-02">
<Title>Attitude/Heading Reference Units (AHRUs)</Title>
<DispatchCondition repairInterval="C" nbrInstalled="2" nbrRequired="1" maintIndicator="(M)">
<DispatchConditionRemarks>
<Para>One may be inoperative provided:</Para>
<List listType="a.">
<ListItem>
<Para>Inoperative AHRU is deactivated.</Para>
</ListItem>
<ListItem>
<Para>IRUs operate normally.</Para>
</ListItem>
</List>
</DispatchConditionRemarks>
<DispatchProcedure>
<MaintenanceProcedure>
<Para>Deactivate the inoperative AHRU (AMM DDG 34-21-01).</Para>
<List listType="1.">
<ListItem>
<Para>For left AHRU inoperative:</Para>
<List listType="A.">
<ListItem>
<Para>Using a flight deck multi-function display only, open circuit breaker ATT HDG REF UNIT-L and lock with an INOP tag.</Para>
</ListItem>
<ListItem>
<Para>Open and collar P300 panel ATT HDG REF UNIT BATTERY-L circuit breaker. </Para>
</ListItem>
</List>
</ListItem>
<ListItem>
<Para>For right AHRU inoperative:</Para>
<List listType="A.">
<ListItem>
<Para>Using a flight deck multi-function display only, open circuit breaker ATT HDG REF UNIT-R and lock with an INOP tag.</Para>
</ListItem>
<ListItem>
<Para>Open and collar P300 panel ATT HDG REF UNIT BATTERY-R circuit breaker. </Para>
</ListItem>
</List>
</ListItem>
</List>
</MaintenanceProcedure>
</DispatchProcedure>
</DispatchCondition>
</MELSubItem>
</MELItem>
