<MELItem itemNbr="34-12-02" id="X-BOEING:FTID:81205.787.DDG.CU.MEL.2-34-12-02.1.2-34-12-02">
<Title>Static Air Data Modules</Title>
<MELSubItem itemNbr="34-12-02-01">
<Title>Right Static Air Data Module</Title>
<DispatchCondition repairInterval="B" nbrInstalled="1" nbrRequired="0">
<DispatchConditionRemarks>
<Para>May be inoperative provided:</Para>
<List listType="a.">
<ListItem>
<Para>Left static air data module operates normally.</Para>
</ListItem>
<ListItem>
<Para>Pitot air data modules operate normally.</Para>
</ListItem>
<ListItem>
<Para>Pitot probe heater systems operate normally.</Para>
</ListItem>
<ListItem>
<Para>AIR DATA/ATT instrument source switches operate normally.</Para>
</ListItem>
<ListItem>
<Para>At least one GPS operates normally.</Para>
</ListItem>
<ListItem>
<Para>Approach minimums do not require its use.</Para>
</ListItem>
</List>
</DispatchConditionRemarks>
<DispatchProcedure>
<MaintenanceNote>
<Para>The left, center and right pitot and static ADMs are interchangeable.</Para>
</MaintenanceNote>
<OperationNote>
<List listType="1.">
<ListItem>
<Para>Maximum landing capability is CAT IIIA.</Para>
</ListItem>
<ListItem>
<Para>The NO LAND 3 advisory message will be displayed.</Para>
</ListItem>
</List>
</OperationNote>
</DispatchProcedure>
</DispatchCondition>
</MELSubItem>
