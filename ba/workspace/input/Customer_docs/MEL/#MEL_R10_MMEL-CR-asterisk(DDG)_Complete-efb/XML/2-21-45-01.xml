<MELItem itemNbr="21-45-01" id="X-BOEING:FTID:81205.787.DDG.CU.MEL.2-21-45-01.1.2-21-45-01">
<Title>Flight Deck Foot Rest Surface Heaters</Title>
<DispatchCondition repairInterval="C" nbrInstalled="4" nbrRequired="0" maintIndicator="(M)">
<DispatchConditionRemarks>
<Para>May be inoperative deactivated.</Para>
</DispatchConditionRemarks>
<DispatchProcedure>
<MaintenanceProcedure>
<Para>Deactivate the inoperative foot heater (AMM DDG 21-45-01).</Para>
<List listType="1.">
<ListItem>
<Para>For captain’s foot heater inoperative:</Para>
<List listType="A.">
<ListItem>
<Para>Using a flight deck multi-function display only, open circuit breaker HEATER-CAPT FOOT and lock with an INOP tag.</Para>
</ListItem>
<ListItem>
<Para>Gain access to captain’s foot heater.</Para>
</ListItem>
<ListItem>
<Para>Disconnect, cap and stow electrical connector to captain’s foot heater.</Para>
</ListItem>
</List>
</ListItem>
<ListItem>
<Para>For first officer’s foot heater inoperative:</Para>
<List listType="A.">
<ListItem>
<Para>Using a flight deck multi-function display only, open circuit breaker HEATER-FO FOOT and lock with an INOP tag.</Para>
</ListItem>
<ListItem>
<Para>Gain access to first officer’s foot heater.</Para>
</ListItem>
<ListItem>
<Para>Disconnect, cap and stow electrical connector to first officer’s foot heater.</Para>
</ListItem>
</List>
</ListItem>
</List>
</MaintenanceProcedure>
</DispatchProcedure>
</DispatchCondition>
</MELItem>
</DispatchItems>