<MELItem itemNbr="52-34-01" id="X-BOEING:FTID:81205.787.DDG.CU.MEL.2-52-34-01.1.2-52-34-01">
<Title>Forward Cargo Door Lift/Latch System (Electric and Manual Modes)</Title>
<DispatchCondition dispCondOptions="A" repairInterval="C" nbrInstalled="2" nbrRequired="1" maintIndicator="(M)">
<Title>One Mode Inoperative</Title>
<DispatchConditionRemarks>
<Para>One may be inoperative provided:</Para>
<List listType="a.">
<ListItem>
<Para>There is no damage to the lift mechanism.</Para>
</ListItem>
<ListItem>
<Para>There is no damage to the latch mechanism.</Para>
</ListItem>
<ListItem>
<Para>Door is operated using the maintenance manual procedure.</Para>
</ListItem>
</List>
</DispatchConditionRemarks>
<DispatchProcedure>
<MaintenanceProcedure>
<Para>Operate the door using the remaining mode (AMM DDG 52-34-01).</Para>
</MaintenanceProcedure>
</DispatchProcedure>
</DispatchCondition>
<DispatchCondition dispCondOptions="B" repairInterval="C" nbrInstalled="2" nbrRequired="0" maintIndicator="(M)">
<Title>Both Modes Inoperative</Title>
<DispatchConditionRemarks>
<Para>May be inoperative provided associated door is verified closed, latched and locked before each departure.</Para>
</DispatchConditionRemarks>
<DispatchProcedure>
<MaintenanceProcedure>
<Para>Before each flight, verify that the associated door is closed, latched and locked (AMM DDG 52-34-01).</Para>
</MaintenanceProcedure>
</DispatchProcedure>
</DispatchCondition>
</MELItem>
</DispatchItems>