<MELItem itemNbr="30-11-01" id="X-BOEING:FTID:81205.787.DDG.CU.MEL.2-30-11-01.1.2-30-11-01_FAA">
<Title>Wing Ice Protection System (WIPS) (*)</Title>
<DispatchCondition repairInterval="C" nbrInstalled="1" nbrRequired="0">
<DispatchConditionRemarks>
<Para>May be inoperative provided:</Para>
<List listType="a.">
<ListItem>
<Para>Airplane is not operated in known or forecast icing conditions.</Para>
</ListItem>
<ListItem>
<Para>EDTO beyond 120 minutes is not conducted.</Para>
</ListItem>
</List>
</DispatchConditionRemarks>
</DispatchCondition>
<MELSubItem itemNbr="30-11-01-01">
<Title>Wing Ice Protection Heat Zones (*)</Title>
<DispatchCondition repairInterval="C" nbrInstalled="48" nbrRequired="46">
<DispatchConditionRemarks>
<Para>One heat zone pair in symmetrical slats may be inoperative.</Para>
</DispatchConditionRemarks>
</DispatchCondition>
</MELSubItem>
<MELSubItem itemNbr="30-11-01-02">
<Title>Wing Ice Protection Channels (*)</Title>
<DispatchCondition repairInterval="C" nbrInstalled="3" nbrRequired="2">
<DispatchConditionRemarks>
<Para>One may be inoperative.</Para>
</DispatchConditionRemarks>
</DispatchCondition>
</MELSubItem>
</MELItem>
