<MELItem itemNbr="28-11-01" id="X-BOEING:FTID:81205.787.DDG.CU.MEL.2-28-11-01.1.2-28-11-01">
<Title>Sump Drain Valves</Title>
<MELSubItem itemNbr="28-11-01-01">
<Title>Surge Tanks</Title>
<DispatchCondition repairInterval="C" nbrInstalled="2" nbrRequired="0" maintIndicator="(M)">
<DispatchConditionRemarks>
<Para>May be inoperative provided there is no evidence of leakage.</Para>
</DispatchConditionRemarks>
<DispatchProcedure>
<MaintenanceProcedure>
<Para>Verify that there is no evidence of fuel leakage (AMM DDG 28-11-01).</Para>
<List listType="1.">
<ListItem>
<Para>Visually inspect exterior surface location of the inoperative sump drain valve to confirm that there is no evidence of fuel leakage.</Para>
</ListItem>
</List>
</MaintenanceProcedure>
</DispatchProcedure>
</DispatchCondition>
</MELSubItem>
<MELSubItem itemNbr="28-11-01-02">
<Title>Main and Center Tanks</Title>
<DispatchCondition repairInterval="C" nbrInstalled="4" nbrRequired="3" maintIndicator="(M)">
<DispatchConditionRemarks>
<Para>One may be inoperative provided:</Para>
<List listType="a.">
<ListItem>
<Para>There is no evidence of leakage.</Para>
</ListItem>
<ListItem>
<Para>Maintenance procedures are used to prevent water accumulation in associated tank.</Para>
</ListItem>
</List>
</DispatchConditionRemarks>
<DispatchProcedure>
<MaintenanceProcedure>
<Para>Verify that there is no evidence of fuel leakage and use alternate procedures to prevent water accumulation in associated tank (AMM DDG 28-11-01).</Para>
<List listType="1.">
<ListItem>
<Para>Visually inspect exterior surface location of the inoperative sump drain valve to verify that there is no evidence of fuel leakage.</Para>
</ListItem>
<ListItem>
<Para>Use alternate procedures to prevent water accumulation in the associated tank.</Para>
</ListItem>
</List>
</MaintenanceProcedure>
</DispatchProcedure>
</DispatchCondition>
</MELSubItem>
</MELItem>
</DispatchItems>