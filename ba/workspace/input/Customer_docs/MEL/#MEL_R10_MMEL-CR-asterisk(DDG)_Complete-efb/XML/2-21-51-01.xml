<DispatchCondition repairInterval="C" nbrInstalled="2" nbrRequired="1" maintIndicator="(M)">
<DispatchConditionRemarks>
<Para>One may be inoperative provided:</Para>
<List listType="a.">
<ListItem>
<Para>Inoperative CAC is deactivated.</Para>
</ListItem>
<ListItem>
<Para>Right air conditioning pack operates normally.</Para>
</ListItem>
<ListItem>
<Para>VFSG associated with operating right CAC operates normally.</Para>
</ListItem>
<ListItem>
<Para>Trim air systems operate normally.</Para>
</ListItem>
<ListItem>
<Para>For OFCR or OFAR occupied and one opposite side Cabin Air Compressor inoperative, airplane remains at or below FL 350.</Para>
</ListItem>
</List>
</DispatchConditionRemarks>
<DispatchProcedure>
<MaintenanceProcedure>
<Para>Use MEL item 21-51-01-02-01-01 (M) procedure.</Para>
</MaintenanceProcedure>
<OperationNote>
<Para>Use MEL item 21-51-01-02-01-01 operations note.</Para>
</OperationNote>
</DispatchProcedure>
</DispatchCondition>
</MELSubItem>
<MELSubItem itemNbr="21-51-01-02-02-03">
<Title>787-9 (VN-A861, VN-A862, VN-A863, VN-A864, VN-A867, VN-A868, VN-A870, VN-A871)</Title>
<DispatchCondition repairInterval="C" nbrInstalled="2" nbrRequired="0" maintIndicator="(M)">
<DispatchConditionRemarks>
<Para>May be inoperative provided:</Para>
<List listType="a.">
<ListItem>
<Para>Right CACs are deactivated.</Para>
</ListItem>
<ListItem>
<Para>Right air conditioning pack is considered inoperative.</Para>
</ListItem>
<ListItem>
<Para>Left trim air system operates normally.</Para>
</ListItem>
<ListItem>
<Para>For OFCR or OFAR occupied, airplane remains at or below FL 350.</Para>
</ListItem>
<ListItem>
<Para>VFSGs associated with left CACs operate normally.</Para>
</ListItem>
</List>
</DispatchConditionRemarks>
<Note>
<Para>The airplane must also be dispatched using MEL item 21-52-01.</Para>
</Note>
<DispatchProcedure>
<MaintenanceProcedure>
<Para>Use MEL item 21-51-01-02-01-01 (M) procedure.</Para>
</MaintenanceProcedure>
<OperationNote>
<Para>Use MEL item 21-51-01-02-01-01 operations note.</Para>
</OperationNote>
</DispatchProcedure>
</DispatchCondition>
</MELSubItem>
</MELSubItem>
</MELSubItem>
</MELItem>
</DispatchItems>