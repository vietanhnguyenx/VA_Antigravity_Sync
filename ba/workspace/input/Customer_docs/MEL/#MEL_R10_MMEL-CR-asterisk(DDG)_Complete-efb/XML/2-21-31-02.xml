<MELItem itemNbr="21-31-02" id="X-BOEING:FTID:81205.787.DDG.CU.MEL.2-21-31-02.1.2-21-31-02">
<Title>Manual Cabin Pressure Outflow Valve Controls (FWD and AFT)</Title>
<DispatchCondition dispCondOptions="A" repairInterval="C" nbrInstalled="2" nbrRequired="1">
<Title>Extended Overwater Flight Prohibited</Title>
<DispatchConditionRemarks>
<Para>One may be inoperative provided:</Para>
<List listType="a.">
<ListItem>
<Para>Automatic cabin pressure control channels on associated valve control unit operate normally.</Para>
</ListItem>
<ListItem>
<Para>Extended overwater flight is prohibited.</Para>
</ListItem>
</List>
</DispatchConditionRemarks>
</DispatchCondition>
<DispatchCondition dispCondOptions="B" repairInterval="C" nbrInstalled="2" nbrRequired="0">
<Title>Outflow Valve Considered Inoperative</Title>
<DispatchConditionRemarks>
<Para>May be inoperative provided associated outflow valve is considered inoperative.</Para>
</DispatchConditionRemarks>
<Note>
<Para>The airplane must be dispatched using MEL item 21-31-03, 21-31-03-01 or 21-31-03-02, as appropriate.</Para>
</Note>
</DispatchCondition>
</MELItem>
</DispatchItems>