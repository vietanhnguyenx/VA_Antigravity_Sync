<MELItem itemNbr="22-31-03" id="X-BOEING:FTID:81205.787.DDG.CU.MEL.2-22-31-03.1.2-22-31-03">
<Title>Autothrottle Disconnect Switches</Title>
<DispatchCondition dispCondOptions="A" repairInterval="C" nbrInstalled="2" nbrRequired="1">
<Title>One Inoperative</Title>
<DispatchConditionRemarks>
<Para>One may be inoperative provided both A/T ARM switches operate normally.</Para>
</DispatchConditionRemarks>
</DispatchCondition>
<DispatchCondition dispCondOptions="B" repairInterval="C" nbrInstalled="2" nbrRequired="0">
<Title>Both Inoperative</Title>
<DispatchConditionRemarks>
<Para>May be inoperative provided:</Para>
<List listType="a.">
<ListItem>
<Para>EEC normal mode operates normally.</Para>
</ListItem>
<ListItem>
<Para>Autothrottles are not armed.</Para>
</ListItem>
<ListItem>
<Para>Approach minimums do not require use of autothrottles.</Para>
</ListItem>
<ListItem>
<Para>EDTO beyond 180 minutes is not conducted.</Para>
</ListItem>
<ListItem>
<Para>Maximum landing capability is CAT IIIA.</Para>
</ListItem>
</List>
</DispatchConditionRemarks>
</DispatchCondition>
</MELItem>
</DispatchItems>