<MELItem itemNbr="23-24-01" id="X-BOEING:FTID:81205.787.DDG.CU.MEL.2-23-24-01.1.2-23-24-01">
<Title>Tuning and Control Panels (TCP)</Title>
<DispatchCondition repairInterval="C" nbrInstalled="3" nbrRequired="2">
<DispatchConditionRemarks>
<Para>One may be inoperative provided:</Para>
<List listType="a.">
<ListItem>
<Para>Left tuning and control panel operates normally.</Para>
</ListItem>
<ListItem>
<Para>Inoperative tuning and control panel remains OFF.</Para>
</ListItem>
</List>
</DispatchConditionRemarks>
<DispatchProcedure>
<MaintenanceNote>
<Para>The tuning and control panels are interchangeable.</Para>
<Para>When the TCP S/W CONFIG status message is displayed, the associated tuning and control panel must be considered inoperative.</Para>
</MaintenanceNote>
</DispatchProcedure>
</DispatchCondition>
