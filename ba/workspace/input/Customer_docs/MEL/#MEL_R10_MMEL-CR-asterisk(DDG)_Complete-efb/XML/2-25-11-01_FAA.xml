<MELItem itemNbr="25-11-01" id="X-BOEING:FTID:81205.787.DDG.CU.MEL.2-25-11-01.1.2-25-11-01_FAA">
<Title>Flight Crew Seats</Title>
<MELSubItem itemNbr="25-11-01-01">
<Title>Power Adjustment Systems</Title>
<DispatchCondition repairInterval="D" nbrInstalled="2" nbrRequired="0" maintIndicator="(M)">
<DispatchConditionRemarks>
<Para>May be inoperative deactivated.</Para>
</DispatchConditionRemarks>
<DispatchProcedure>
<MaintenanceProcedure>
<Para>Deactivate inoperative flight crew seat power adjustment system (AMM DDG 25-11-01).</Para>
<Para>For inoperative power adjustment system on captain’s seat, using a flight deck multi-function display only, open circuit breaker FLT DK SEAT - CAPT and lock with an INOP tag.</Para>
<Para>For inoperative power adjustment system on first officer’s seat, using a flight deck multi-function display only, open circuit breaker FLT DK SEAT - FO and lock with an INOP tag.</Para>
</MaintenanceProcedure>
</DispatchProcedure>
</DispatchCondition>
</MELSubItem>
<MELSubItem itemNbr="25-11-01-02">
<Title>Manual Adjustment System</Title>
<MELSubItem itemNbr="25-11-01-02-01">
<Title>Recline Systems</Title>
<DispatchCondition repairInterval="A" nbrInstalled="2" nbrRequired="0" maintIndicator="(M)">
<DispatchConditionRemarks>
<Para>May be inoperative provided:</Para>
<List listType="a.">
<ListItem>
<Para>Seat is secured in an upright position acceptable to the affected crew member.</Para>
</ListItem>
<ListItem>
<Para>Repairs are made within two flight days.</Para>
</ListItem>
</List>
</DispatchConditionRemarks>
<DispatchProcedure>
<MaintenanceProcedure>
<Para>Secure the associated seat backrest in a position that is acceptable to the affected flight crew member (AMM DDG 25-11-01).</Para>
</MaintenanceProcedure>
</DispatchProcedure>
</DispatchCondition>
</MELSubItem>
<MELSubItem itemNbr="25-11-01-02-02">
<Title>Vertical Adjustments</Title>
<DispatchCondition repairInterval="C" nbrInstalled="2" nbrRequired="0">
<DispatchConditionRemarks>
<Para>May be inoperative provided associated vertical power adjustment system operates normally.</Para>
</DispatchConditionRemarks>
</DispatchCondition>
</MELSubItem>
<MELSubItem itemNbr="25-11-01-02-03">
<Title>Armrests</Title>
<DispatchCondition repairInterval="B" nbrInstalled="4" nbrRequired="0" maintIndicator="(M)">
<DispatchConditionRemarks>
<Para>May be inoperative provided:</Para>
<List listType="a.">
<ListItem>
<Para>Affected armrest is stowed in the retracted position or removed.</Para>
</ListItem>
<ListItem>
<Para>Seat is acceptable to affected crew member.</Para>
</ListItem>
</List>
</DispatchConditionRemarks>
<DispatchProcedure>
<MaintenanceProcedure>
<Para>Remove or stow the armrest in the retracted position (AMM DDG 25-11-01).</Para>
</MaintenanceProcedure>
</DispatchProcedure>
</DispatchCondition>
</MELSubItem>
<MELSubItem itemNbr="25-11-01-02-04">
<Title>Lumbar/Thigh Supports</Title>
<DispatchCondition repairInterval="C" nbrInstalled="4" nbrRequired="0">
<DispatchConditionRemarks>
<Para>May be inoperative provided seat is acceptable to the affected crew member.</Para>
</DispatchConditionRemarks>
</DispatchCondition>
</MELSubItem>
<MELSubItem itemNbr="25-11-01-02-05">
<Title>Headrests</Title>
<DispatchCondition repairInterval="C" nbrInstalled="2" nbrRequired="0">
<DispatchConditionRemarks>
<Para>May be inoperative provided seat is acceptable to the affected crew member.</Para>
</DispatchConditionRemarks>
</DispatchCondition>
</MELSubItem>
<MELSubItem itemNbr="25-11-01-02-06">
<Title>Seat Pan Tilt</Title>
<DispatchCondition repairInterval="C" nbrInstalled="2" nbrRequired="0" maintIndicator="(M)">
<DispatchConditionRemarks>
<Para>May be inoperative provided: </Para>
<List listType="a.">
<ListItem>
<Para>Associated seat pan is secured in the horizontal (untilted) position.</Para>
</ListItem>
<ListItem>
<Para>Seat is acceptable to affected crew member.</Para>
</ListItem>
</List>
</DispatchConditionRemarks>
<DispatchProcedure>
<MaintenanceProcedure>
<Para>Secure seat in the horizontal (untilted) position using an appropriate lockout pin (AMM DDG 25-11-01).</Para>
</MaintenanceProcedure>
</DispatchProcedure>
</DispatchCondition>
</MELSubItem>
</MELSubItem>
</MELItem>
</DispatchItems>