<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:bioc="http://bpmn.io/schema/bpmn/biocolor/1.0" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="bpmn-js (https://demo.bpmn.io)" exporterVersion="18.13.2">
  <bpmn:collaboration id="Collaboration_1">
    <bpmn:participant id="Participant_Target" name="Hệ thống Đích (Target System)" processRef="Process_Target" />
    <bpmn:participant id="Participant_TTHDL" name="Trục Tích hợp Dữ liệu (TTHDL)" processRef="Process_TTHDL" />
    <bpmn:participant id="Participant_Client" name="Phân hệ nội bộ / Đối tác (Client)" />
    <bpmn:messageFlow id="MsgFlow_1" targetRef="Event_GW_Start" />
    <bpmn:messageFlow id="MsgFlow_2" sourceRef="Task_Route" targetRef="Event_Target_Start" />
    <bpmn:messageFlow id="MsgFlow_3" sourceRef="Event_Target_End" targetRef="Event_GW_Wait" />
    <bpmn:messageFlow id="MsgFlow_4" sourceRef="Task_Return" />
  </bpmn:collaboration>
  <bpmn:process id="Process_Target" isExecutable="false">
    <bpmn:task id="Task_Target_Process" name="Xử lý Nghiệp vụ" />
    <bpmn:endEvent id="Event_Target_End" name="Trả Kết quả" />
    <bpmn:sequenceFlow id="Flow_T1" sourceRef="Event_Target_Start" targetRef="Task_Target_Process" />
    <bpmn:sequenceFlow id="Flow_T2" sourceRef="Task_Target_Process" targetRef="Event_Target_End" />
    <bpmn:startEvent id="Event_Target_Start" name="Nhận API" />
  </bpmn:process>
  <bpmn:process id="Process_TTHDL" isExecutable="false">
    <bpmn:laneSet id="LaneSet_1">
      <bpmn:lane id="Lane_Monitor" name="Module Quản trị (Monitor UI)">
        <bpmn:flowNodeRef>Mod_Auth</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Mod_RateLimit</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Mod_Key</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Mod_Log</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Mod_Route</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Mod_Alert</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Mod_Report</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Gateway" name="API Gateway (Luồng Tích hợp)">
        <bpmn:flowNodeRef>Event_GW_Start</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Auth</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gate_Auth</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Err401</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Event_Err401</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_RateLimit</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gate_RateLimit</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Err403</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Event_Err403</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Decrypt</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_LogReq</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Route</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Event_GW_Wait</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Encrypt</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_LogRes</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gate_Parallel</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Alert</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Report</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Return</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:task id="Mod_Auth" name="QL Tài khoản Xác thực" />
    <bpmn:task id="Mod_RateLimit" name="QL Dịch vụ &#38; Rate Limit" />
    <bpmn:task id="Mod_Key" name="Thiết lập Khóa mã hóa" />
    <bpmn:task id="Mod_Log" name="Nhật ký hệ thống" />
    <bpmn:task id="Mod_Route" name="Thiết lập Luồng tích hợp" />
    <bpmn:task id="Mod_Alert" name="Cấu hình Ngưỡng Cảnh báo" />
    <bpmn:task id="Mod_Report" name="Báo cáo Thống kê" />
    <bpmn:startEvent id="Event_GW_Start" name="Tiếp nhận Request">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:task id="Task_Auth" name="Xác thực Tài khoản">
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gate_Auth" name="Hợp lệ?">
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_Auth_No</bpmn:outgoing>
      <bpmn:outgoing>Flow_Auth_Yes</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_Err401" name="Trả lỗi 401">
      <bpmn:incoming>Flow_Auth_No</bpmn:incoming>
      <bpmn:outgoing>Flow_Err401_End</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="Event_Err401">
      <bpmn:incoming>Flow_Err401_End</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:task id="Task_RateLimit" name="Kiểm tra Quyền &#38; Rate Limit">
      <bpmn:incoming>Flow_Auth_Yes</bpmn:incoming>
      <bpmn:outgoing>Flow_3</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gate_RateLimit" name="Hợp lệ?">
      <bpmn:incoming>Flow_3</bpmn:incoming>
      <bpmn:outgoing>Flow_RL_No</bpmn:outgoing>
      <bpmn:outgoing>Flow_RL_Yes</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_Err403" name="Trả lỗi 403 / 429">
      <bpmn:incoming>Flow_RL_No</bpmn:incoming>
      <bpmn:outgoing>Flow_Err403_End</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="Event_Err403">
      <bpmn:incoming>Flow_Err403_End</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:task id="Task_Decrypt" name="Giải mã Payload">
      <bpmn:incoming>Flow_RL_Yes</bpmn:incoming>
      <bpmn:outgoing>Flow_4</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_LogReq" name="Ghi nhận Log Request">
      <bpmn:incoming>Flow_4</bpmn:incoming>
      <bpmn:outgoing>Flow_5</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_Route" name="Định tuyến &#38; Chuyển đổi">
      <bpmn:incoming>Flow_5</bpmn:incoming>
      <bpmn:outgoing>Flow_6</bpmn:outgoing>
    </bpmn:task>
    <bpmn:intermediateCatchEvent id="Event_GW_Wait" name="Nhận Response">
      <bpmn:incoming>Flow_6</bpmn:incoming>
      <bpmn:outgoing>Flow_7</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MessageEventDefinition_1" />
    </bpmn:intermediateCatchEvent>
    <bpmn:task id="Task_Encrypt" name="Mã hóa Payload">
      <bpmn:incoming>Flow_7</bpmn:incoming>
      <bpmn:outgoing>Flow_8</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_LogRes" name="Cập nhật Log Response">
      <bpmn:incoming>Flow_8</bpmn:incoming>
      <bpmn:outgoing>Flow_9</bpmn:outgoing>
    </bpmn:task>
    <bpmn:parallelGateway id="Gate_Parallel">
      <bpmn:incoming>Flow_9</bpmn:incoming>
      <bpmn:outgoing>Flow_10</bpmn:outgoing>
      <bpmn:outgoing>Flow_11</bpmn:outgoing>
      <bpmn:outgoing>Flow_12</bpmn:outgoing>
    </bpmn:parallelGateway>
    <bpmn:task id="Task_Alert" name="Kiểm tra Cảnh báo">
      <bpmn:incoming>Flow_10</bpmn:incoming>
    </bpmn:task>
    <bpmn:task id="Task_Report" name="Thống kê Dashboard">
      <bpmn:incoming>Flow_11</bpmn:incoming>
    </bpmn:task>
    <bpmn:task id="Task_Return" name="Trả kết quả Client">
      <bpmn:incoming>Flow_12</bpmn:incoming>
    </bpmn:task>
    <bpmn:sequenceFlow id="Flow_1" sourceRef="Event_GW_Start" targetRef="Task_Auth" />
    <bpmn:sequenceFlow id="Flow_2" sourceRef="Task_Auth" targetRef="Gate_Auth" />
    <bpmn:sequenceFlow id="Flow_Auth_No" name="Sai" sourceRef="Gate_Auth" targetRef="Task_Err401" />
    <bpmn:sequenceFlow id="Flow_Err401_End" sourceRef="Task_Err401" targetRef="Event_Err401" />
    <bpmn:sequenceFlow id="Flow_Auth_Yes" name="Đúng" sourceRef="Gate_Auth" targetRef="Task_RateLimit" />
    <bpmn:sequenceFlow id="Flow_3" sourceRef="Task_RateLimit" targetRef="Gate_RateLimit" />
    <bpmn:sequenceFlow id="Flow_RL_No" name="Sai" sourceRef="Gate_RateLimit" targetRef="Task_Err403" />
    <bpmn:sequenceFlow id="Flow_Err403_End" sourceRef="Task_Err403" targetRef="Event_Err403" />
    <bpmn:sequenceFlow id="Flow_RL_Yes" name="Đúng" sourceRef="Gate_RateLimit" targetRef="Task_Decrypt" />
    <bpmn:sequenceFlow id="Flow_4" sourceRef="Task_Decrypt" targetRef="Task_LogReq" />
    <bpmn:sequenceFlow id="Flow_5" sourceRef="Task_LogReq" targetRef="Task_Route" />
    <bpmn:sequenceFlow id="Flow_6" sourceRef="Task_Route" targetRef="Event_GW_Wait" />
    <bpmn:sequenceFlow id="Flow_7" sourceRef="Event_GW_Wait" targetRef="Task_Encrypt" />
    <bpmn:sequenceFlow id="Flow_8" sourceRef="Task_Encrypt" targetRef="Task_LogRes" />
    <bpmn:sequenceFlow id="Flow_9" sourceRef="Task_LogRes" targetRef="Gate_Parallel" />
    <bpmn:sequenceFlow id="Flow_10" sourceRef="Gate_Parallel" targetRef="Task_Alert" />
    <bpmn:sequenceFlow id="Flow_11" sourceRef="Gate_Parallel" targetRef="Task_Report" />
    <bpmn:sequenceFlow id="Flow_12" sourceRef="Gate_Parallel" targetRef="Task_Return" />
    <bpmn:association id="Assoc_1_Element" sourceRef="Mod_Auth" targetRef="Task_Auth" />
    <bpmn:association id="Assoc_2_Element" sourceRef="Mod_RateLimit" targetRef="Task_RateLimit" />
    <bpmn:association id="Assoc_3_Element" sourceRef="Mod_Key" targetRef="Task_Decrypt" />
    <bpmn:association id="Assoc_4_Element" sourceRef="Mod_Log" targetRef="Task_LogReq" />
    <bpmn:association id="Assoc_5_Element" sourceRef="Mod_Route" targetRef="Task_Route" />
    <bpmn:association id="Assoc_6_Element" sourceRef="Mod_Key" targetRef="Task_Encrypt" />
    <bpmn:association id="Assoc_7_Element" sourceRef="Mod_Log" targetRef="Task_LogRes" />
    <bpmn:association id="Assoc_8_Element" sourceRef="Mod_Alert" targetRef="Task_Alert" />
    <bpmn:association id="Assoc_9_Element" sourceRef="Mod_Report" targetRef="Task_Report" />
  </bpmn:process>
