# ===== TOSS — .aiignore =====
# Ngăn AI agent nạp các thư mục không liên quan vào context.
# Tên file: .aiignore (Roo Code), .cursorignore (Cursor), .continueignore (Continue)
# → Sao chép file này nếu extension dùng tên khác.

# --- Thư mục runtime / build (không phải source of truth) ---
logs/
ba/output/human/

# --- File binary (agent không đọc được, chỉ tốn slot) ---
*.docx
*.xlsx
*.pdf
*.pptx
*.png
*.jpg
*.jpeg

# --- Slide QA / assets trung gian ---
_qa3/

# --- DEV (bổ sung khi có code) ---
node_modules/
dist/
build/
bin/
obj/
coverage/
*.log
.env
.env.local

# --- OS / editor ---
.git/
.vscode/
.idea/
Thumbs.db
.DS_Store
